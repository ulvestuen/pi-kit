    57	  /** Artifacts produced by this task. */
    58	  outputArtifacts?: ArtifactRef[];
    59	  /** Tool calls made during execution. */
    60	  toolCalls?: { tool: string; args: unknown; result: string }[];
    61	  /** Token usage, when available from the child. */
