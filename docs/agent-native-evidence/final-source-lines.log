   130	function nameKey(name: string): string {
   131	  return name.trim().toLowerCase();
   132	}
   133	
   134	/** A failed review with a diagnostic weakness — the unparseable path. */
   135	function failedReview(raw: string, reason: string): ReviewResult {
   136	  return {
   137	    scores: [],
   138	    passed: false,
   139	    weaknesses: [`unscorable output: ${reason}`],
   140	    raw,
   141	  };
   142	}
   143	
   144	/** Extract candidate JSON payloads from the critic's reply, best first. */
   145	function extractJsonCandidates(text: string): string[] {
   146	  const candidates: string[] = [];
   147	  // Fenced blocks first (last one wins the top spot — the verdict comes last).
   148	  const fenced = [...text.matchAll(/```(?:json)?\s*\n([\s\S]*?)```/g)];
   149	  for (const match of fenced.reverse()) {
   150	    candidates.push(match[1]);
   151	  }
   152	  // Fallback: bare {...} regions that mention "scores".
   153	  const braceStart = text.indexOf("{");
   154	  if (braceStart !== -1) {
   155	    const braceEnd = text.lastIndexOf("}");
   156	    if (braceEnd > braceStart) {
   157	      candidates.push(text.slice(braceStart, braceEnd + 1));
   158	    }
   159	  }
   160	  return candidates;
   161	}
   162	
   163	/**
   164	 * Parse the critic's reply into a ReviewResult: tolerant JSON-block
   165	 * extraction, per-criterion validation, and score clamping. Never throws on
   166	 * bad critic output — an unscorable review fails loudly instead.
   167	 */
   168	export function parseCriticOutput(
   169	  text: string,
   170	  req: ReviewRequest,
   171	): ReviewResult {
   172	  validateRequest(req);
   173	  const raw = text ?? "";
   174	
   175	  let parsed: any = null;
   176	  for (const candidate of extractJsonCandidates(raw)) {
   177	    try {
   178	      const value = JSON.parse(candidate);
   179	      if (value && typeof value === "object" && Array.isArray(value.scores)) {
   180	        parsed = value;
   181	        break;
   182	      }
   183	    } catch {
   184	      // try the next candidate
   185	    }
   186	  }
   187	  if (!parsed) {
   188	    return failedReview(raw, "no valid JSON scores block found in the reply");
   189	  }
   190	
   191	  const byKey = new Map<string, { score: number; weakness?: string }>();
   192	  for (const entry of parsed.scores) {
   193	    const name = typeof entry?.name === "string" ? entry.name.trim() : "";
   194	    if (!name) continue;
   195	    const scoreNum = Number(entry.score);
   196	    if (!Number.isFinite(scoreNum)) continue;
   197	    byKey.set(nameKey(name), {
   198	      score: clampScore(scoreNum, req.scaleMax),
   199	      weakness:
   200	        typeof entry.weakness === "string" && entry.weakness.trim()
   201	          ? entry.weakness.trim()
   202	          : undefined,
   203	    });
   204	  }
   205	
   206	  const missing = req.criteria.filter((c) => !byKey.has(nameKey(c.name)));
   207	  if (missing.length > 0) {
   208	    return failedReview(
   209	      raw,
   210	      `criteria not scored: ${missing.map((c) => c.name).join(", ")}`,
   211	    );
   212	  }
   213	
   214	  const scores: CriterionScore[] = req.criteria.map((c) => {
   215	    const entry = byKey.get(nameKey(c.name))!;
   216	    return { name: c.name, score: entry.score, weakness: entry.weakness };
   217	  });
   218	
   219	  const failing = scores
   220	    .map((score) => ({
   221	      score,
   222	      threshold: req.criteria.find((c) => nameKey(c.name) === nameKey(score.name))!
   223	        .threshold,
   224	    }))
   225	    .filter(({ score, threshold }) => score.score < threshold)
   226	    .sort(
   227	      (a, b) => a.score.score - a.threshold - (b.score.score - b.threshold),
   228	    );
   229	
   230	  return {
   231	    scores,
   232	    passed: failing.length === 0,
   233	    weaknesses: failing.map(({ score, threshold }) =>
   234	      score.weakness
   235	        ? `${score.name}: ${score.weakness}`
   236	        : `${score.name}: scored ${score.score}/${threshold} with no stated weakness`,
   237	    ),
   238	    raw,
   239	  };
   240	}
