   241	/**
   242	 * Create a fleet-compatible SpawnFn whose labeled pi children run through the
   243	 * spawn backend machinery and whose unlabeled helper commands use fallback.
   244	 */
   245	export function createSpawnToolingSpawn(
   246	  options: SpawnToolingSpawnOptions,
   247	): SpawnFn {
   248	  const backendName = options.backend ?? options.config.backend;
   249	  const backend = options.backends[backendName];
   250	  if (!backend) {
   251	    throw new Error(`Unknown spawn backend "${backendName}"`);
   252	  }
   253	  const pollIntervalMs = options.pollIntervalMs ?? DEFAULT_POLL_INTERVAL_MS;
   254	  const outputMaxBytes = options.outputMaxBytes ?? DEFAULT_OUTPUT_MAX_BYTES;
   255	  const parentPid = options.parentPid ?? process.pid;
   256	  const deadlineMs = options.deadlineMs;
   257	  const now = options.now ?? Date.now;
   258	  const sleep =
   259	    options.sleep ?? ((ms: number) => new Promise<void>((r) => setTimeout(r, ms)));
   260	
   261	  let registryChain: Promise<unknown> = Promise.resolve();
   262	
   263	  async function withJobs<T>(
   264	    fn: (jobs: SpawnJob[]) => Promise<{ result: T; dirty: boolean }> | { result: T; dirty: boolean },
   265	  ): Promise<T> {
   266	    const run = registryChain.then(async () => {
   267	      const jobs = loadJobs(options.config.logDir, options.onRegistryError);
   268	      const { result, dirty } = await fn(jobs);
   269	      if (dirty) saveJobs(options.config.logDir, jobs);
   270	      return result;
   271	    });
   272	    registryChain = run.catch(() => undefined);
   273	    return run;
   274	  }
   275	
   276	  async function saveJob(job: SpawnJob): Promise<void> {
   277	    await withJobs((jobs) => {
   278	      const index = jobs.findIndex((candidate) => candidate.name === job.name);
   279	      if (index === -1) jobs.push(job);
   280	      else jobs[index] = job;
   281	      return { result: undefined, dirty: true };
   282	    });
   283	  }
   284	
   285	  /**
   286	   * Send the kill command via the backend and stamp the registry.
   287	   *
   288	   * ADR §6/§9 define three exhaustive branches after backend.kill():
   289	   *
   290	   *  1. **stopped** (KillResult.stopped === true)
   291	   *     The backend confirmed the process is no longer running.
   292	   *     → Stamp "killed" immediately. No done-marker probe needed.
   293	   *
   294	   *  2. **alreadyComplete** (KillResult.alreadyComplete === true, stopped false)
   295	   *     The backend says the process already exited before the kill.
   296	   *     → Refresh from the done marker to discover the real terminal
   297	   *       status (done/failed). If the marker is missing or corrupt
   298	   *       (refresh cannot resolve), stamp "lost" so the job never
   299	   *       stays "running" forever.
   300	   *
   301	   *  3. **warned / unconfirmed** (both stopped and alreadyComplete false)
   302	   *     The kill signal was sent but the backend cannot confirm the
   303	   *     process stopped — it may still be running ("nonterminal") or
   304	   *     it may have exited during the race ("terminal" after refresh).
   305	   *     → Refresh from done markers. If still nonterminal, stamp "lost"
   306	   *       to prevent the job from staying "running" forever. If the
   307	   *       refresh resolves to a terminal status, use that.
   308	   *
   309	   * A thrown exception from backend.kill() is caught and converted to a
   310	   * warned/unconfirmed KillResult (stopped=false, no alreadyComplete),
   311	   * following the same path as branch 3.
   312	   */
   313	  async function killAndStamp(job: SpawnJob): Promise<KillResult> {
   314	    // Terminal jobs need no kill; treat as alreadyComplete.
   315	    if (isTerminal(job.status)) {
   316	      return { stopped: false, alreadyComplete: true };
   317	    }
   318	    let result: KillResult;
   319	    try {
   320	      result = await backend.kill(job);
   321	    } catch (e: any) {
   322	      // KillResult branch 3 entry: convert thrown error to warned/unconfirmed.
   323	      result = { stopped: false, message: e?.message ?? String(e) };
   324	    }
   325	    if (result.alreadyComplete && !result.stopped) {
   326	      // KillResult branch 2 — alreadyComplete: refresh from done marker to discover
   327	      // the real terminal status (done/failed).  If the marker cannot
   328	      // resolve, stamp lost so the job never stays "running".
   329	      try {
   330	        await backend.refresh(job);
   331	      } catch {
   332	        // Best-effort; the backend already confirmed completion.
   333	      }
   334	      if (!isTerminal(job.status)) {
   335	        // Backend confirmed completion but refresh could not resolve the
   336	        // status (missing/corrupt marker); mark lost.
   337	        job.status = "lost";
   338	      }
   339	      job.updatedAt = now();
   340	      await saveJob(job);
   341	      return result;
   342	    }
   343	    if (result.stopped) {
   344	      // KillResult branch 1 — stopped: backend confirms the process is gone.
   345	      // Stamp killed immediately per ADR §6/§9.
   346	      job.status = "killed";
   347	      job.updatedAt = now();
   348	      await saveJob(job);
   349	      return result;
   350	    }
   351	    // KillResult branch 3 — warned / unconfirmed: backend could not confirm stop
   352	    // and the job is not already complete.  The process may still be
   353	    // running (nonterminal) or may have exited during the race (terminal
   354	    // after refresh).  Refresh from done markers; if still nonterminal,
   355	    // stamp "lost" so the job does not stay "running" forever.
   356	    try {
   357	      await backend.refresh(job);
   358	    } catch {
   359	      // Best-effort.
   360	    }
   361	    if (!isTerminal(job.status)) {
   362	      job.status = "lost";
   363	    }
   364	    job.updatedAt = now();
   365	    await saveJob(job);
   366	    return result;
   367	  }
   368	
   369	  return async (request: SpawnRequest): Promise<SpawnOutcome> => {
   370	    // The fleet runner labels only the pi sub-agent child. Auxiliary commands
   371	    // such as git worktree setup must remain ordinary helper processes.
   372	    if (!request.label) {
   373	      if (!options.fallback) {
   374	        throw new Error(
   375	          `spawn tooling received unlabeled helper command without a fallback: ${request.command}`,
   376	        );
   377	      }
   378	      return options.fallback(request);
   379	    }
   380	
   381	    if (request.signal.aborted) {
   382	      return { exitCode: null, stdout: "", stderr: "spawn job aborted before launch" };
   383	    }
   384	
   385	    const unavailable = await backend.available();
   386	    if (unavailable) {
   387	      throw new Error(`Backend "${backendName}" is not usable here: ${unavailable}`);
   388	    }
   389	
   390	    const job = await withJobs(async (jobs) => {
   391	      const jobName = uniqueJobName(
   392	        `${options.jobNamePrefix ?? "runner"}-${request.label}`,
   393	        (candidate) => jobs.some((existing) => existing.name === candidate),
   394	        now(),
   395	      );
   396	      const launched = await backend.launch({
   397	        jobName,
   398	        agent: pseudoAgent(request.label),
   399	        task: taskPreview(request),
   400	        cwd: request.cwd,
   401	        command: request.command,
   402	        args: request.args,
   403	      });
   404	      launched.parentPid = parentPid;
   405	      jobs.push(launched);
   406	      return { result: launched, dirty: true };
   407	    });
   408	
   409	    let stdout = "";
   410	    let streamed = "";
   411	    const startedAt = now();
   412	
   413	    const streamOutput = async () => {
   414	      const latest = normalizeOutput(await backend.output(job, outputMaxBytes));
   415	      stdout = latest;
   416	      if (latest.length > streamed.length && latest.startsWith(streamed)) {
   417	        const delta = latest.slice(streamed.length);
   418	        streamed = latest;
   419	        request.onOutput?.(delta);
   420	      } else if (latest !== streamed) {
   421	        streamed = latest;
   422	        // If a backend returns a truncated/non-prefix tail, emit the available
   423	        // chunk rather than silently hiding progress.
   424	        request.onOutput?.(latest);
   425	      }
   426	    };
   427	
   428	    const onAbort = () => {
   429	      // Wake-up is bounded by pollIntervalMs; actual kill is awaited in-loop so
   430	      // the returned outcome and registry state are consistent.
   431	    };
   432	    request.signal.addEventListener("abort", onAbort, { once: true });
   433	
   434	    try {
   435	      for (;;) {
   436	        if (request.signal.aborted || (deadlineMs !== undefined && now() - startedAt >= deadlineMs)) {
   437	          await killAndStamp(job);
   438	          await streamOutput();
   439	          const deadlineReason = request.signal.aborted
   440	            ? "spawn job aborted"
   441	            : `spawn job exceeded hard deadline of ${deadlineMs} ms`;
   442	          return {
   443	            exitCode: null,
   444	            stdout,
   445	            stderr: `${deadlineReason}\n${await reportStderr(backend, job)}`,
   446	          };
   447	        }
   448	
   449	        const changed = await backend.refresh(job);
   450	        if (changed) await saveJob(job);
   451	        await streamOutput();
   452	
   453	        if (isTerminal(job.status)) {
   454	          await saveJob(job);
   455	          return {
   456	            exitCode: statusExit(job),
   457	            stdout,
   458	            stderr: await reportStderr(backend, job),
   459	          };
   460	        }
   461	
   462	        await sleep(pollIntervalMs);
   463	      }
   464	    } finally {
   465	      request.signal.removeEventListener("abort", onAbort);
   466	    }
   467	  };
   468	}
