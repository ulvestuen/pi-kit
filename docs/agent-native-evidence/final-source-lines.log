   603	          `  Plan:        ${plan ? `${summarizePlan(plan).counts.done}/${plan.tasks.length} done — "${plan.goal}"` : "(none)"}`,
   604	          missing.length > 0
   605	            ? `  MISSING dependencies: ${missing.join(", ")} — install the lykkja and planner packages.`
