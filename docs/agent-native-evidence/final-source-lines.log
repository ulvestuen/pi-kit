    65	export type RunnerEvent =
    66	  | { type: "task_start"; index: number; agent: string; task: string }
    67	  | { type: "task_update"; index: number; agent: string; chunk: string }
    68	  | { type: "task_end"; index: number; agent: string; result: TaskResult };
    69	
    70	/** Request handed to the injected spawn function. */
