   176	    if (!parsed || typeof parsed !== "object" || Array.isArray(parsed)) {
   177	      throw new Error(`spawn config ${configPath} must contain a JSON object`);
   178	    }
   179	    return { raw: parsed as RawSpawnConfig, configPath };
   180	  }
   181	  return {
   182	    raw: {
   183	      backend: process.env.SPAWN_BACKEND,
   184	      logDir: process.env.SPAWN_LOG_DIR,
   185	      piBinary: process.env.SPAWN_PI_BINARY,
