    95	  /** Run one prompt through the critic agent and return its final message. */
    96	  async function dispatchCritic(
    97	    cwd: string,
    98	    prompt: string,
    99	    signal: AbortSignal | undefined,
   100	    runId?: RunId,
   101	  ): Promise<{ output: string; status: string }> {
   102	    const def = criticAgent(cwd);
   103	    const registry = new Map([[def.name.toLowerCase(), def]]);
   104	    const [result] = await runTasks(
   105	      registry,
   106	      [{ agent: def.name, task: prompt, timeoutMs: config.timeoutMs, runId }],
   107	      {
   108	        spawn,
   109	        cwd,
   110	        piBinary: config.piBinary,
   111	        maxConcurrent: 1,
   112	        signal,
   113	        saveFullOutput: createFullOutputSaver("pi-critic"),
   114	      },
   115	    );
   116	    return { output: result.output, status: result.status };
   117	  }
