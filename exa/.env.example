# Exa API key — get one from https://dashboard.exa.ai/api-keys
EXA_API_KEY=your_exa_api_key_here

# Optional API base URL (default: https://api.exa.ai)
EXA_BASE_URL=https://api.exa.ai

# Default number of results to return, 1-100 (default: 5)
EXA_NUM_RESULTS=5

# Search type: auto, neural, keyword, fast, deep, deep-reasoning, instant (default: auto)
EXA_SEARCH_TYPE=auto

# Whether to fetch page text contents with each result (default: true)
EXA_INCLUDE_TEXT=true

# Max characters of page text to include per result, 0 = uncapped (default: 1000)
EXA_MAX_CHARACTERS=1000

# Optional default Exa category filter, e.g. news, research paper, github, company, pdf
# EXA_CATEGORY=news
