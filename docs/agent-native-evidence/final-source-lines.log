     1	/**
     2	 * microsandbox backend — jobs run inside a local microVM (hardware
     3	 * isolation) instead of directly on this machine.
     4	 *
     5	 * The job directory is volume-mounted into the guest at /job, so the run
     6	 * script, log, and done marker are the *same files* on both sides: the
     7	 * guest writes them, the host reads them with the shared local helpers.
     8	 * The `msb run` process itself is started detached on the host and is the
     9	 * job's runner; its pid is the aliveness probe (no msb calls needed).
    10	 *
    11	 * The guest needs `pi`: the default `node` image gets it via a one-time
    12	 * `npm install -g` in the run script when missing. API keys are forwarded
    13	 * as export lines inside the run script (a 0700 host file), never on the
    14	 * msb command line.
    15	 *
    16	 * CLI contract per https://docs.microsandbox.dev/cli/overview:
    17	 * `msb run --name X -v host:/guest IMAGE -- CMD`, `msb stop|rm --force X`.
    18	 */
    19	
    20	import { chmodSync, mkdirSync, writeFileSync } from "node:fs";
    21	import * as path from "node:path";
    22	import {
    23	  buildEnvExports,
    24	  buildPiShellCommand,
    25	  buildShellCommand,
    26	} from "../agent-command.ts";
    27	import type { SpawnConfig } from "../config.ts";
    28	import {
    29	  isTerminal,
    30	  type DetachEffects,
    31	  type ExecFn,
    32	  type LaunchRequest,
    33	  type SpawnBackend,
    34	  type SpawnJob,
    35	} from "../jobs.ts";
    36	import type { BackendCapabilities, KillResult } from "@pi-kit/agent-types";
    37	import {
    38	  localJobDir,
    39	  readErrTail,
    40	  readLogTail,
    41	  refreshFromLocalMarkers,
    42	} from "./local.ts";
    43	
    44	/** Where the job directory appears inside the guest. */
    45	export const GUEST_JOB_DIR = "/job";
    46	/** Where the job's cwd appears inside the guest when mounted. */
    47	export const GUEST_WORKSPACE_DIR = "/workspace";
    48	
    49	export function sandboxNameFor(jobName: string): string {
    50	  return `pi-spawn-${jobName}`;
    51	}
    52	
    53	/**
    54	 * The run script executed inside the guest. Paths are guest paths (the
    55	 * mounted /job), so the done marker and log land in the host job dir.
    56	 *
    57	 * Like the tmux script: stderr goes to its own err file so it never
    58	 * pollutes the parsed output stream, guard-rail failures explain
    59	 * themselves in that err file before writing the done marker, and the
    60	 * exit code is staged and only published as the done marker after the
    61	 * log is fully written — the marker's appearance means the log is
    62	 * complete on the host side of the mount too.
    63	 */
    64	export function buildGuestRunScript(options: {
    65	  jobName: string;
    66	  piCommand: string;
    67	  envExports: string[];
    68	  mountCwd: boolean;
    69	}): string {
    70	  const done = `${GUEST_JOB_DIR}/done`;
    71	  const exit = `${GUEST_JOB_DIR}/done.exit`;
    72	  const err = `${GUEST_JOB_DIR}/err.log`;
    73	  const cdTarget = options.mountCwd ? GUEST_WORKSPACE_DIR : `"\${HOME:-/root}"`;
    74	  return [
    75	    "#!/bin/sh",
    76	    `# pi-spawn job ${options.jobName}: one detached sub-agent in this microVM.`,
    77	    ...options.envExports,
    78	    `command -v pi > /dev/null 2>&1 || npm install -g @mariozechner/pi-coding-agent > ${GUEST_JOB_DIR}/setup.log 2>&1 || { echo '[pi-spawn] could not install pi in the sandbox; see setup.log in the job directory' > ${err}; echo 126 > ${done}; exit 126; }`,
    79	    `cd ${cdTarget} || { echo "[pi-spawn] could not cd to ${options.mountCwd ? GUEST_WORKSPACE_DIR : "\\$HOME"} in the sandbox" > ${err}; echo 127 > ${done}; exit 127; }`,
    80	    `{ ${options.piCommand}; echo $? > ${exit}; } > ${GUEST_JOB_DIR}/job.log 2> ${err}`,
    81	    `mv ${exit} ${done}`,
    82	    "",
    83	  ].join("\n");
    84	}
