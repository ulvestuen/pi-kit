    51	function summarizeResult(index: number, spec: TaskSpec, r: TaskResult): string {
    52	  const header = `[${index + 1}] ${r.agent} — ${r.status.toUpperCase()} in ${Math.round(r.durationMs / 1000)}s`;
    53	  const lines = [header];
    54	  if (r.branch) lines.push(`    branch: ${r.branch} (worktree: ${r.worktreePath})`);
    55	  if (r.truncated && r.fullOutputPath) {
    56	    lines.push(`    output truncated; full transcript: ${r.fullOutputPath}`);
    57	  }
    58	  const body = r.output.trim();
    59	  if (body) lines.push(body);
    60	  return lines.join("\n");
    61	}
