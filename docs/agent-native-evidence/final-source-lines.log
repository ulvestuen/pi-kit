   152	/** git arguments that create a task worktree on a new branch.
   153	 * When parentBranch is given the worktree is forked from that branch
   154	 * instead of the current HEAD — enabling prerequisite branch handoff.
   155	 */
   156	export function buildWorktreeArgs(
   157	  branch: string,
   158	  path: string,
   159	  parentBranch?: string,
   160	): string[] {
   161	  return ["worktree", "add", "-b", branch, ...(parentBranch ? [parentBranch] : []), path];
   162	}
   163	
   164	/** Derive a unique branch name / worktree directory name for a task. */
   165	export function worktreeBranchName(index: number, startedAt: number): string {
   166	  return `fleet/task-${index + 1}-${startedAt}`;
   167	}
   168	
   169	export interface ParsedPiOutput {
   170	  /** Text of the final assistant message. */
   171	  text: string;
   172	  /** Error message when the run ended in an error/aborted stop reason. */
   173	  errorMessage?: string;
   174	}
   175	
   176	/**
   177	 * Extract the final assistant message from a pi `--mode json` JSONL stream.
   178	 * Tolerant of non-JSON lines; the last assistant `message_end` event wins.
   179	 */
   180	export function parsePiJsonOutput(stdout: string): ParsedPiOutput {
   181	  let lastAssistant: any = null;
   182	  for (const line of stdout.split("\n")) {
   183	    const trimmed = line.trim();
   184	    if (!trimmed.startsWith("{")) continue;
   185	    let event: any;
   186	    try {
   187	      event = JSON.parse(trimmed);
   188	    } catch {
   189	      continue;
   190	    }
   191	    if (event?.type === "message_end" && event.message?.role === "assistant") {
   192	      lastAssistant = event.message;
   193	    }
   194	  }
   195	
   196	  if (!lastAssistant) {
   197	    return { text: "", errorMessage: "no assistant message in child output" };
   198	  }
   199	
   200	  if (
   201	    lastAssistant.stopReason === "error" ||
   202	    lastAssistant.stopReason === "aborted"
   203	  ) {
   204	    return {
   205	      text: "",
   206	      errorMessage:
   207	        lastAssistant.errorMessage || `child ${lastAssistant.stopReason}`,
   208	    };
   209	  }
   210	
   211	  const text = (lastAssistant.content ?? [])
   212	    .filter((c: any) => c?.type === "text")
   213	    .map((c: any) => c.text)
   214	    .join("\n");
   215	  return { text };
   216	}
   217	
   218	/** Cap a string at a byte budget (UTF-8), marking whether it was cut. */
   219	export function capOutput(
   220	  text: string,
   221	  capBytes: number,
   222	): { output: string; truncated: boolean } {
   223	  let bytes = 0;
   224	  for (let i = 0; i < text.length; i++) {
   225	    const code = text.codePointAt(i)!;
   226	    bytes += code <= 0x7f ? 1 : code <= 0x7ff ? 2 : code <= 0xffff ? 3 : 4;
   227	    if (code > 0xffff) i++;
   228	    if (bytes > capBytes) {
   229	      return {
   230	        output: `${text.slice(0, i)}\n[... output truncated at ${capBytes} bytes ...]`,
   231	        truncated: true,
   232	      };
   233	    }
   234	  }
   235	  return { output: text, truncated: false };
   236	}
   237	
   238	interface ResolvedOptions {
   239	  spawn: SpawnFn;
   240	  cwd: string;
   241	  piBinary: string;
   242	  maxConcurrent: number;
   243	  maxBatch: number;
   244	  defaultTimeoutMs: number;
   245	  outputCapBytes: number;
   246	  signal?: AbortSignal;
   247	  onEvent?: (e: RunnerEvent) => void;
   248	  saveFullOutput?: RunnerOptions["saveFullOutput"];
   249	  worktreeRoot?: string;
   250	  now: () => number;
   251	}
   252	
   253	function resolveOptions(options: RunnerOptions): ResolvedOptions {
   254	  const maxConcurrent = options.maxConcurrent ?? DEFAULT_MAX_CONCURRENT;
   255	  const maxBatch = options.maxBatch ?? DEFAULT_MAX_BATCH;
   256	  if (!Number.isFinite(maxConcurrent) || maxConcurrent < 1) {
   257	    throw new Error(`maxConcurrent must be at least 1 (got: ${maxConcurrent})`);
   258	  }
   259	  if (!Number.isFinite(maxBatch) || maxBatch < 1) {
   260	    throw new Error(`maxBatch must be at least 1 (got: ${maxBatch})`);
   261	  }
   262	  if (!options.cwd) {
   263	    throw new Error("runner cwd is required");
   264	  }
   265	  return {
   266	    spawn: options.spawn,
   267	    cwd: options.cwd,
   268	    piBinary: options.piBinary ?? DEFAULT_PI_BINARY,
   269	    maxConcurrent: Math.floor(maxConcurrent),
   270	    maxBatch: Math.floor(maxBatch),
   271	    defaultTimeoutMs: options.defaultTimeoutMs ?? DEFAULT_TIMEOUT_MS,
   272	    outputCapBytes: options.outputCapBytes ?? DEFAULT_OUTPUT_CAP_BYTES,
   273	    signal: options.signal,
   274	    onEvent: options.onEvent,
   275	    saveFullOutput: options.saveFullOutput,
   276	    worktreeRoot: options.worktreeRoot,
   277	    now: options.now ?? Date.now,
   278	  };
   279	}
   280	
   281	function validateTasks(
   282	  registry: Map<string, AgentDefinition>,
   283	  tasks: TaskSpec[],
   284	  opts: ResolvedOptions,
   285	): void {
   286	  if (!Array.isArray(tasks) || tasks.length === 0) {
   287	    throw new Error("At least one task is required");
   288	  }
   289	  if (tasks.length > opts.maxBatch) {
   290	    throw new Error(
   291	      `Batch of ${tasks.length} tasks exceeds the maximum of ${opts.maxBatch}; split it into smaller batches`,
   292	    );
   293	  }
   294	  const known = [...registry.values()].map((d) => d.name).sort();
   295	  for (const spec of tasks) {
   296	    if (!spec.task || !spec.task.trim()) {
   297	      throw new Error("Every task needs non-empty task text");
   298	    }
   299	    if (!getAgent(registry, spec.agent)) {
   300	      throw new Error(
   301	        `Unknown agent "${spec.agent}". Known agents: ${known.join(", ") || "(none)"}`,
   302	      );
   303	    }
   304	    if (spec.isolation === "worktree" && !opts.worktreeRoot) {
   305	      throw new Error(
   306	        'isolation "worktree" requires a worktreeRoot in runner options',
   307	      );
   308	    }
   309	  }
   310	}
   311	
   312	async function runOneTask(
   313	  registry: Map<string, AgentDefinition>,
   314	  spec: TaskSpec,
   315	  index: number,
   316	  opts: ResolvedOptions,
   317	): Promise<TaskResult> {
   318	  const def = getAgent(registry, spec.agent)!;
   319	  const startedAt = opts.now();
   320	  opts.onEvent?.({
   321	    type: "task_start",
   322	    index,
   323	    agent: def.name,
   324	    task: spec.task,
   325	  });
   326	
   327	  const controller = new AbortController();
   328	  let timedOut = false;
   329	  const timeoutMs = spec.timeoutMs ?? opts.defaultTimeoutMs;
   330	  const timer = setTimeout(() => {
   331	    timedOut = true;
   332	    controller.abort();
   333	  }, timeoutMs);
   334	  const onExternalAbort = () => controller.abort();
   335	  opts.signal?.addEventListener("abort", onExternalAbort, { once: true });
   336	
   337	  const finish = async (
   338	    partial: Omit<TaskResult, "agent" | "durationMs">,
   339	    transcript?: string,
   340	  ): Promise<TaskResult> => {
   341	    clearTimeout(timer);
   342	    opts.signal?.removeEventListener("abort", onExternalAbort);
   343	    const result: TaskResult = {
   344	      agent: def.name,
   345	      durationMs: opts.now() - startedAt,
   346	      runId: spec.runId,
   347	      ...partial,
   348	    };
   349	    if (transcript && opts.saveFullOutput) {
   350	      try {
   351	        result.fullOutputPath = await opts.saveFullOutput(
   352	          index,
   353	          spec,
   354	          transcript,
   355	        );
   356	      } catch {
   357	        // Transcript persistence is best-effort; the result stands without it.
   358	      }
   359	    }
   360	    opts.onEvent?.({ type: "task_end", index, agent: def.name, result });
   361	    return result;
   362	  };
   363	
   364	  try {
   365	    let cwd = spec.cwd ?? opts.cwd;
   366	    let branch: string | undefined;
   367	    let worktreePath: string | undefined;
   368	
   369	    if (spec.isolation === "worktree") {
   370	      branch = worktreeBranchName(index, startedAt);
   371	      worktreePath = `${opts.worktreeRoot}/${branch.replace(/\//g, "-")}`;
   372	      const wt = await opts.spawn({
   373	        command: "git",
   374	        args: buildWorktreeArgs(branch, worktreePath, spec.parentBranch),
   375	        cwd,
   376	        signal: controller.signal,
   377	      });
   378	      if (wt.exitCode !== 0) {
   379	        return finish({
   380	          status: controller.signal.aborted
   381	            ? timedOut
   382	              ? "timeout"
   383	              : "aborted"
   384	            : "error",
   385	          output: `git worktree add failed: ${wt.stderr.trim() || wt.stdout.trim()}`,
   386	          truncated: false,
   387	          exitCode: wt.exitCode ?? undefined,
   388	        });
   389	      }
   390	      cwd = worktreePath;
   391	    }
   392	
   393	    const outcome = await opts.spawn({
   394	      command: opts.piBinary,
   395	      args: buildPiArgs(def, spec),
   396	      cwd,
   397	      signal: controller.signal,
   398	      label: `${index + 1}-${def.name}`,
   399	      onOutput: (chunk) =>
   400	        opts.onEvent?.({ type: "task_update", index, agent: def.name, chunk }),
   401	    });
   402	
   403	    if (controller.signal.aborted) {
   404	      return finish(
   405	        {
   406	          status: timedOut ? "timeout" : "aborted",
   407	          output: timedOut
   408	            ? `task timed out after ${timeoutMs} ms`
   409	            : "task aborted",
   410	          truncated: false,
   411	          exitCode: outcome.exitCode ?? undefined,
   412	          branch,
   413	          worktreePath,
   414	        },
   415	        outcome.stdout,
   416	      );
   417	    }
   418	
   419	    const parsed = parsePiJsonOutput(outcome.stdout);
   420	    if (outcome.exitCode !== 0 || parsed.errorMessage) {
   421	      // On a non-zero exit the child's stderr is the primary evidence; the
   422	      // parse complaint ("no assistant message ...") is just its shadow.
   423	      const detail =
   424	        (outcome.exitCode !== 0
   425	          ? outcome.stderr.trim() || parsed.errorMessage
   426	          : parsed.errorMessage || outcome.stderr.trim()) ||
   427	        "child process failed";
   428	      return finish(
   429	        {
   430	          status: "error",
   431	          output: `child failed (exit ${outcome.exitCode}): ${detail}`,
   432	          truncated: false,
   433	          exitCode: outcome.exitCode ?? undefined,
   434	          branch,
   435	          worktreePath,
   436	        },
   437	        outcome.stdout,
   438	      );
   439	    }
   440	
   441	    const { output, truncated } = capOutput(parsed.text, opts.outputCapBytes);
   442	    return finish(
   443	      {
   444	        status: "ok",
   445	        output,
   446	        truncated,
   447	        exitCode: 0,
   448	        branch,
   449	        worktreePath,
   450	      },
   451	      outcome.stdout,
   452	    );
   453	  } catch (e: any) {
   454	    if (controller.signal.aborted) {
   455	      return finish({
   456	        status: timedOut ? "timeout" : "aborted",
   457	        output: timedOut
   458	          ? `task timed out after ${timeoutMs} ms`
   459	          : "task aborted",
   460	        truncated: false,
   461	      });
   462	    }
   463	    return finish({
   464	      status: "error",
   465	      output: `spawn failed: ${e?.message ?? e}`,
   466	      truncated: false,
   467	    });
   468	  }
   469	}
   470	
   471	function abortedResult(
   472	  spec: TaskSpec,
   473	  index: number,
   474	  opts: ResolvedOptions,
   475	): TaskResult {
   476	  const result: TaskResult = {
   477	    agent: spec.agent,
   478	    status: "aborted",
   479	    output: "task aborted before start",
   480	    truncated: false,
   481	    durationMs: 0,
   482	    runId: spec.runId,
   483	  };
   484	  opts.onEvent?.({ type: "task_end", index, agent: spec.agent, result });
   485	  return result;
   486	}
   487	
   488	/**
   489	 * Run a batch of tasks through a FIFO concurrency pool.
   490	 *
   491	 * Results are returned in task order. An external abort marks queued tasks
   492	 * "aborted" immediately and cancels running children via their spawn signal.
   493	 */
   494	export async function runTasks(
   495	  registry: Map<string, AgentDefinition>,
   496	  tasks: TaskSpec[],
   497	  options: RunnerOptions,
   498	): Promise<TaskResult[]> {
   499	  const opts = resolveOptions(options);
   500	  validateTasks(registry, tasks, opts);
   501	
   502	  const results: TaskResult[] = new Array(tasks.length);
   503	  let next = 0;
   504	
   505	  const worker = async (): Promise<void> => {
   506	    while (next < tasks.length) {
   507	      const index = next++;
   508	      const spec = tasks[index];
   509	      if (opts.signal?.aborted) {
   510	        results[index] = abortedResult(spec, index, opts);
   511	        continue;
   512	      }
   513	      results[index] = await runOneTask(registry, spec, index, opts);
   514	    }
   515	  };
   516	
   517	  const workers = Array.from(
   518	    { length: Math.min(opts.maxConcurrent, tasks.length) },
   519	    () => worker(),
   520	  );
   521	  await Promise.all(workers);
   522	  return results;
   523	}
