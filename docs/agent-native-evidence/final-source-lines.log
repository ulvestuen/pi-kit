   497	              lines.push(`      - ${weakness}`);
   498	            }
   499	            if (!review.passed) {
   500	              const now = plan.tasks.find(
   501	                (t) => t.id.toLowerCase() === id.toLowerCase(),
   502	              )!;
   503	              lines.push(
   504	                `      -> ${now.status === "failed" ? "attempt limit reached, task FAILED" : "re-queued with critic feedback in the brief"}`,
   505	              );
   506	            }
   507	          }
   508	        }
   509	
   510	        const branches = [...resultsById.entries()]
   511	          .filter(([id, r]) => r.branch && plan!.tasks.find((t) => t.id === id)?.status === "done")
   512	          .map(([id, r]) => `${r.branch} (${id})`);
   513	        if (branches.length > 0) {
   514	          lines.push(
   515	            "",
   516	            `Branches that passed review, to merge serially in DAG order: ${branches.join(", ")}`,
   517	          );
   518	        }
   519	
   520	        lines.push(
   521	          "",
   522	          `Plan: ${summary.counts.done}/${summary.total} done, ${summary.counts.ready + summary.counts.pending} waiting, ${summary.counts.review} in review, ${summary.counts.failed} failed.` +
   523	            (summary.ready.length > 0 ? ` Ready next: ${summary.ready.join(", ")}.` : ""),
   524	          "",
   525	          "AUTOMATED NEXT STEP:",
   526	          `1. Call lykkja_checkpoint for this wave now: plan = "wave ${wave}: dispatch ${dispatched.map((t) => t.id).join(", ") || "(reviews only)"}", changes = a one-line wave summary, scores = every goal-level criterion scored honestly using the critic verdicts above as evidence — do not inflate.`,
   527	          "2. On ITERATING: call orchestrate_step again immediately" +
   528	            (summary.counts.failed > 0
   529	              ? " — but first repair the plan with plan_update (follow-up tasks addressing the recorded weaknesses, or explicit descoping) since tasks have failed."
   530	              : "."),
   531	          "3. On FINAL: merge any listed branches, then summarize the run. On STOPPED: report honestly which criteria still fail.",
   532	        );
   533	
   534	        return {
   535	          content: [{ type: "text" as const, text: lines.join("\n") }],
   536	          details: {
   537	            wave,
   538	            terminal: decision.terminal,
   539	            dispatched: dispatched.map((t) => t.id),
   540	            results: Object.fromEntries(resultsById),
   541	            reviews: Object.fromEntries(reviewsById),
   542	            summary,
   543	            runLog: [
   544	              { timestamp: Date.now(), type: "wave_start", wave, runId: { runId: `wave-${wave}`, taskId: "", attempt: 0, wave }, payload: { dispatch: dispatched.map((t) => t.id) } },
   545	              ...[...resultsById.entries()].map(([id, r]) => ({
   546	                timestamp: Date.now(),
   547	                type: "task_end" as const,
   548	                runId: r.runId ?? { runId: `task-${id}`, taskId: id, attempt: 1, wave },
   549	                payload: { taskId: id, status: r.status, durationMs: r.durationMs },
   550	              })),
   551	              ...[...reviewsById.entries()].map(([id, rev]) => ({
   552	                timestamp: Date.now(),
   553	                type: "task_end" as const,
   554	                runId: { runId: `review-${id}`, taskId: id, attempt: 0, wave },
   555	                payload: { taskId: id, review: { passed: rev.passed, scoreCount: rev.scores.length } },
   556	              })),
   557	              { timestamp: Date.now(), type: "wave_end", wave, runId: { runId: `wave-${wave}-end`, taskId: "", attempt: 0, wave }, payload: {} },
   558	            ],
   559	          },
   560	        };
   561	      },
   562	    }),
   563	  );
