   664	// Comprehensive end-to-end: legacy plain-text + structured artifact handoff
   665	// ---------------------------------------------------------------------------
   666	
   667	describe("end-to-end: legacy plain-text task → structured artifact handoff to dependent task", () => {
   668	  it("drives a 2-task DAG to FINAL: legacy task completes, dependent receives artifacts via brief without shared context, critic evidence persists on retry", () => {
   669	    // --- Setup: t1 (legacy plain-text) -> t2 (structured dependent) ---
   670	    let plan = createPlan(
   671	      "ship the feature",
   672	      [
   673	        task("t1", {
   674	          description: "Implement the parser module",
   675	        }),
   676	        task("t2", {
   677	          dependsOn: ["t1"],
   678	          description: "Write integration tests for the parser",
   679	        }),
   680	      ],
   681	      { now: 1000 },
   682	    );
   683	
   684	    const loop = createLoop({
   685	      task: "ship the feature",
   686	      criteria: ["all plan tasks done", "every task passed critic review"],
   687	      now: 1,
   688	    });
   689	
   690	    // --- Phase 1: dispatch t1 (legacy plain-text, no RunId) ---
   691	    const decision1 = nextActions(plan, policy);
   692	    assert.deepStrictEqual(decision1.dispatch.map((t) => t.id), ["t1"]);
   693	    assert.strictEqual(decision1.terminal, "running");
   694	
   695	    // Dispatch t1 — plain TaskResult with no agent-native fields (legacy path)
   696	    plan = setPlanTaskRunning(plan, "t1");
   697	    plan = applyTaskResult(
   698	      plan,
   699	      "t1",
   700	      okResult({ output: "parser implemented" }),
   701	      policy,
   702	    );
   703	    assert.strictEqual(getTask(plan, "t1")!.status, "review");
   704	
   705	    // Critic passes t1
   706	    plan = applyReview(plan, "t1", review(true), policy);
   707	    assert.strictEqual(getTask(plan, "t1")!.status, "done");
   708	
   709	    // Record artifacts for t1 (simulates orchestrator's recordPassingArtifacts)
   710	    const t1Artifacts: ArtifactRef[] = [
   711	      {
   712	        type: "branch",
   713	        id: "feat-parser",
   714	        description: "Branch feat-parser with completed parser changes",
   715	        location: "fleet/t1-w1-a1",
   716	      },
   717	      {
   718	        type: "summary",
   719	        id: "t1-summary",
   720	        description: "Summary of task t1: Implement the parser module",
   721	      },
   722	    ];
   723	    plan = updateTask(plan, "t1", { artifacts: t1Artifacts });
   724	
   725	    // --- Phase 2: verify artifact handoff section for t2 ---
   726	    const t2 = getTask(plan, "t2")!;
   727	    const handoff = buildHandoffSection(plan, t2);
   728	    assert.ok(handoff.length > 0, "handoff section should not be empty");
   729	    assert.match(handoff, /Prerequisite artifacts/);
   730	    assert.match(handoff, /\[t1\]/);
   731	    assert.match(handoff, /branch:.*feat-parser/);
   732	    assert.match(handoff, /summary:.*Implement the parser/);
   733	
   734	    // Verify the brief builder would include the handoff
   735	    // (buildTaskBrief is private, but we can verify the handoff function
   736	    // produces the right content that gets spliced into the brief)
   737	    const handoffLines = handoff.split("\n");
   738	    assert.ok(handoffLines.some((l) => l.includes("branch")));
   739	    assert.ok(handoffLines.some((l) => l.includes("fleet/t1-w1-a1")));
   740	
   741	    // --- Phase 3: dispatch t2 with structured artifacts in brief context ---
   742	    const decision2 = nextActions(plan, policy);
   743	    assert.deepStrictEqual(decision2.dispatch.map((t) => t.id), ["t2"]);
   744	
   745	    // t2 runs — first attempt fails review (critic finds weakness)
   746	    plan = setPlanTaskRunning(plan, "t2");
   747	    plan = applyTaskResult(
   748	      plan,
   749	      "t2",
   750	      okResult({ output: "tests written" }),
   751	      policy,
   752	    );
   753	    plan = applyReview(
   754	      plan,
   755	      "t2",
   756	      review(false, ["tests: missing edge case for empty input"]),
   757	      policy,
   758	    );
   759	    // t2 should be re-queued with critic feedback in the brief
   760	    assert.strictEqual(getTask(plan, "t2")!.status, "ready");
   761	    assert.match(
   762	      getTask(plan, "t2")!.description,
   763	      /Review of attempt 1 FAILED/,
   764	    );
   765	    assert.match(
   766	      getTask(plan, "t2")!.description,
   767	      /missing edge case for empty input/,
   768	    );
   769	    // Artifacts from t1 should still be accessible in the plan
   770	    assert.strictEqual(getTask(plan, "t1")!.artifacts.length, 2);
   771	    assert.strictEqual(getTask(plan, "t1")!.artifacts[0].type, "branch");
   772	
   773	    // t2 retry — second attempt passes
   774	    plan = setPlanTaskRunning(plan, "t2");
   775	    plan = applyTaskResult(
   776	      plan,
   777	      "t2",
   778	      okResult({ output: "tests written with edge cases" }),
   779	      policy,
   780	    );
   781	    plan = applyReview(plan, "t2", review(true), policy);
   782	    assert.strictEqual(getTask(plan, "t2")!.status, "done");
   783	
   784	    // Verify retry counts
   785	    assert.strictEqual(getTask(plan, "t1")!.attempts, 1);
   786	    assert.strictEqual(getTask(plan, "t2")!.attempts, 2);
   787	
   788	    // --- Phase 4: goal loop reaches FINAL ---
   789	    const summary = summarizePlan(plan);
   790	    assert.strictEqual(summary.done, true, "every plan task is done");
   791	
   792	    const { decision: finalAct } = recordCheckpoint(loop, {
