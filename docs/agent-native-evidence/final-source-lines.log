   491	              .map((s) => `${s.name} ${s.score}/${scaleMax}`)
   492	              .join(", ");
   493	            lines.push(
   494	              `  [${id}] ${review.passed ? "PASSED" : "FAILED"}${scoreText ? ` (${scoreText})` : ""}`,
