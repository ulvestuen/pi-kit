     1	/**
     2	 * orchestrator scheduler — pure, deterministic state machine over the
     3	 * planner's plan model (the "loop.ts" of this extension).
     4	 *
     5	 * Hard control flow (waves, retries, stops) lives here in code; judgment
     6	 * (decomposition, scoring, plan repair) stays with the models. Imports only
     7	 * pure cores: planner/plan.ts types and functions, fleet/runner.ts and
     8	 * critic/review.ts result shapes.
     9	 */
    10	
    11	import type { TaskResult } from "../fleet/runner.ts";
    12	import type { ReviewResult } from "../critic/review.ts";
    13	import {
    14	  getTask,
    15	  readySet,
    16	  setTaskStatus,
    17	  updateTask,
    18	  type Plan,
    19	  type PlanTask,
    20	} from "../planner/plan.ts";
    21	
    22	export const DEFAULT_MAX_ATTEMPTS = 2;
    23	
    24	export interface SchedulerPolicy {
    25	  /** Dispatch-wave width, forwarded to the fleet runner. */
    26	  maxConcurrent: number;
    27	  /** Per-task dispatch cap; a task failing review at the cap goes "failed". */
    28	  maxAttempts: number;
    29	}
    30	
    31	export interface DispatchDecision {
    32	  /** Ready tasks to send to fleet now (bounded by free capacity). */
    33	  dispatch: PlanTask[];
    34	  /** Completed tasks awaiting the critic's verdict. */
    35	  reviews: PlanTask[];
    36	  /** blocked = a failed task blocks the rest of the DAG. */
    37	  terminal: "running" | "complete" | "blocked";
    38	}
    39	
    40	function validatePolicy(policy: SchedulerPolicy): void {
    41	  if (!Number.isFinite(policy.maxConcurrent) || policy.maxConcurrent < 1) {
    42	    throw new Error(
    43	      `maxConcurrent must be at least 1 (got: ${policy.maxConcurrent})`,
    44	    );
    45	  }
    46	  if (!Number.isFinite(policy.maxAttempts) || policy.maxAttempts < 1) {
    47	    throw new Error(
    48	      `maxAttempts must be at least 1 (got: ${policy.maxAttempts})`,
    49	    );
    50	  }
    51	}
    52	
    53	/** Compute what to do next: which tasks to dispatch, review, or whether the
    54	 * run is complete/blocked. Pure — does not modify the plan. */
    55	export function nextActions(
    56	  plan: Plan,
    57	  policy: SchedulerPolicy,
    58	): DispatchDecision {
    59	  validatePolicy(policy);
    60	
    61	  const reviews = plan.tasks.filter((t) => t.status === "review");
    62	  const running = plan.tasks.filter((t) => t.status === "running").length;
    63	  const capacity = Math.max(0, policy.maxConcurrent - running);
    64	  const dispatch = readySet(plan).slice(0, capacity);
    65	
    66	  const doneCount = plan.tasks.filter((t) => t.status === "done").length;
    67	  let terminal: DispatchDecision["terminal"];
    68	  if (doneCount === plan.tasks.length) {
    69	    terminal = "complete";
    70	  } else if (dispatch.length === 0 && reviews.length === 0 && running === 0) {
    71	    // Nothing can move: every remaining task is failed or waiting on one.
    72	    terminal = "blocked";
    73	  } else {
    74	    terminal = "running";
    75	  }
    76	
    77	  return { dispatch, reviews, terminal };
    78	}
    79	
    80	/** Mark a task dispatched: status "running", which counts the attempt.
    81	 * Promotes pending → ready first so the lifecycle matches the ADR's
    82	 * transition table (pending → ready → running) without triggering a warning. */
    83	export function setPlanTaskRunning(plan: Plan, id: string): Plan {
    84	  const task = getTask(plan, id);
    85	  if (!task) throw new Error(`Unknown task id: ${id}`);
    86	  let p = plan;
    87	  if (task.status === "pending") {
    88	    p = setTaskStatus(p, id, "ready");
    89	  }
    90	  return setTaskStatus(p, id, "running");
    91	}
    92	
    93	/**
    94	 * Fold one fleet TaskResult into the plan.
    95	 * ok → "review" (awaiting the critic); anything else is a failed attempt —
    96	 * retried while attempts < maxAttempts, otherwise "failed".
    97	 */
    98	export function applyTaskResult(
    99	  plan: Plan,
   100	  id: string,
   101	  result: TaskResult,
   102	  policy: SchedulerPolicy,
   103	): Plan {
   104	  validatePolicy(policy);
   105	  const task = getTask(plan, id);
   106	  if (!task) {
   107	    throw new Error(`Unknown task id: ${id}`);
   108	  }
   109	
   110	  if (result.status === "ok") {
   111	    return setTaskStatus(plan, id, "review");
   112	  }
   113	
   114	  const failureNote =
   115	    `Attempt ${task.attempts} ${result.status}: ` +
   116	    `${result.output.trim() || "(no output)"}`;
   117	  const withNote = updateTask(plan, id, {
   118	    description: `${task.description}\n\n[${failureNote}]`,
   119	  });
   120	  return setTaskStatus(
   121	    withNote,
   122	    id,
   123	    task.attempts < policy.maxAttempts ? "ready" : "failed",
   124	  );
   125	}
   126	
   127	/**
   128	 * Fold one critic ReviewResult into the plan.
   129	 * pass → done; fail with attempts < maxAttempts → ready again with the
   130	 * critic's weaknesses appended to the brief; otherwise failed.
   131	 */
   132	export function applyReview(
   133	  plan: Plan,
   134	  id: string,
   135	  review: ReviewResult,
   136	  policy: SchedulerPolicy,
   137	): Plan {
   138	  validatePolicy(policy);
   139	  const task = getTask(plan, id);
   140	  if (!task) {
   141	    throw new Error(`Unknown task id: ${id}`);
   142	  }
   143	  if (task.status !== "review") {
   144	    throw new Error(
   145	      `Task "${id}" is ${task.status}, not awaiting review`,
   146	    );
   147	  }
   148	
   149	  if (review.passed) {
   150	    return setTaskStatus(plan, id, "done");
   151	  }
   152	
   153	  const weaknesses =
   154	    review.weaknesses.length > 0
   155	      ? review.weaknesses.map((w) => `- ${w}`).join("\n")
   156	      : "- (no weaknesses stated)";
   157	  const feedback =
   158	    `Review of attempt ${task.attempts} FAILED. ` +
   159	    `Fix these weaknesses, worst first:\n${weaknesses}`;
   160	  const withFeedback = updateTask(plan, id, {
   161	    description: `${task.description}\n\n[${feedback}]`,
   162	  });
   163	  return setTaskStatus(
   164	    withFeedback,
   165	    id,
   166	    task.attempts < policy.maxAttempts ? "ready" : "failed",
   167	  );
   168	}
