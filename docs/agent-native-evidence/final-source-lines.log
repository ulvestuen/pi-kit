   654	  const streamingInner: SpawnFn = async (req) => {
   655	    const stdout = `${assistantLine("all done")}\n`;
   656	    req.onOutput?.(stdout);
   657	    return { exitCode: 0, stdout, stderr: "" };
   658	  };
