   190	
   191	        let run = await dispatchCritic(ctx.cwd, prompt, signal);
   192	        if (run.status !== "ok") {
   193	          throw new Error(`critic run ${run.status}: ${run.output}`);
   194	        }
   195	        let review = parseCriticOutput(run.output, request);
   196	
   197	        // One automatic re-run before an unscorable review counts.
   198	        if (!review.passed && review.scores.length === 0) {
   199	          run = await dispatchCritic(ctx.cwd, prompt, signal);
   200	          if (run.status === "ok") {
   201	            const retry = parseCriticOutput(run.output, request);
   202	            if (retry.scores.length > 0) review = retry;
   203	          }
   204	        }
