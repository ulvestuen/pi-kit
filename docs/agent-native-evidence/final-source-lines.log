     1	/**
     2	 * planner plan engine — pure, dependency-free model of a plan as data:
     3	 * a validated task DAG with per-task, lykkja-shaped acceptance criteria.
     4	 *
     5	 * The only import is lykkja's pure loop engine, so this module stays free of
     6	 * pi and Node APIs and can be unit tested in isolation and reused by the
     7	 * extension and the orchestrator.
     8	 */
     9	
    10	import {
    11	  DEFAULT_PASS_THRESHOLD,
    12	  DEFAULT_SCALE_MAX,
    13	  normalizeCriteria,
    14	  type Criterion,
    15	  type CriterionInput,
    16	} from "../lykkja/loop.ts";
    17	import type { ArtifactRef } from "@pi-kit/agent-types";
    18	
    19	export const DEFAULT_AGENT = "implementer";
    20	
    21	export type TaskStatus =
    22	  | "pending" // dependencies not yet met
    23	  | "ready" // dispatchable
    24	  | "running"
    25	  | "review" // done, awaiting critic verdict
    26	  | "done"
    27	  | "failed";
    28	
    29	export const TASK_STATUSES: readonly TaskStatus[] = [
    30	  "pending",
    31	  "ready",
    32	  "running",
    33	  "review",
    34	  "done",
    35	  "failed",
    36	];
