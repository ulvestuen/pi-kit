    61	function def(
    62	  name: string,
    63	  overrides: Partial<AgentDefinition> = {},
    64	): AgentDefinition {
    65	  return {
    66	    name,
    67	    description: `${name} description`,
    68	    systemPrompt: `${name} prompt`,
    69	    source: `${name}.md`,
    70	    ...overrides,
    71	  };
    72	}
