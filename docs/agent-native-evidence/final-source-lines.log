    82	interface ExecCall {
    83	  command: string;
    84	  args: string[];
    85	  options?: ExecOptions;
    86	}
    87	
    88	/** Fake ExecFn: routes each call through a handler and records it. */
    89	function fakeExec(
    90	  handler: (call: ExecCall) => Partial<ExecOutcome> | undefined,
    91	): { exec: ExecFn; calls: ExecCall[] } {
    92	  const calls: ExecCall[] = [];
    93	  const exec: ExecFn = async (command, args, options) => {
    94	    const call = { command, args, options };
    95	    calls.push(call);
    96	    const outcome = handler(call) ?? {};
    97	    return { exitCode: 0, stdout: "", stderr: "", ...outcome };
    98	  };
    99	  return { exec, calls };
   100	}
