    29	/** t1 -> t2 -> t4, t1 -> t3 -> t4 diamond. */
    30	function diamond() {
    31	  return createPlan(
    32	    "ship the feature",
    33	    [
    34	      task("t1"),
    35	      task("t2", { dependsOn: ["t1"] }),
    36	      task("t3", { dependsOn: ["t1"] }),
    37	      task("t4", { dependsOn: ["t2", "t3"] }),
    38	    ],
    39	    { now: 1000 },
    40	  );
    41	}
