    86	/** argv for the detached `msb run` that hosts one job. */
    87	export function buildMsbRunArgs(
    88	  config: SpawnConfig,
    89	  jobName: string,
    90	  jobDir: string,
    91	  cwd: string,
    92	): string[] {
    93	  const args = [
    94	    "run",
    95	    "--no-tty",
    96	    "--name",
    97	    sandboxNameFor(jobName),
    98	    "-v",
    99	    `${jobDir}:${GUEST_JOB_DIR}`,
   100	  ];
   101	  if (config.msbMountCwd) {
   102	    const mountMode = config.sandboxReadonlyWorkspace ? ":ro" : "";
   103	    args.push("-v", `${cwd}:${GUEST_WORKSPACE_DIR}${mountMode}`);
   104	  }
   105	  if (config.msbCpus !== undefined) {
   106	    args.push("--cpus", String(config.msbCpus));
   107	  }
   108	  if (config.msbMemory) args.push("--memory", config.msbMemory);
   109	  args.push(config.msbImage, "--", "sh", `${GUEST_JOB_DIR}/run.sh`);
   110	  return args;
   111	}
