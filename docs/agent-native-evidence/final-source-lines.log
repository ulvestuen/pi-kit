    71	    );
    72	    config = {
    73	      scaleMax: 10,
    74	      passThreshold: 8,
    75	      timeoutMs: 5 * 60 * 1000,
    76	      piBinary: "pi",
    77	      tmux: true,
    78	      tmuxSession: DEFAULT_TMUX_SESSION,
    79	      tmuxCloseWindows: false,
    80	    };
    81	  }
    82	
    83	  const spawnConfig = loadHostSpawnConfig(config, "pi-critic");
    84	  const spawnTmuxLive = spawnConfig.backend === "tmux" && isTmuxAvailable();
    85	  const spawn = createHostSpawn(config, "pi-critic", spawnConfig);
    86	
    87	  /** Resolve the critic agent definition, applying the config model override. */
    88	  function criticAgent(cwd: string): AgentDefinition {
    89	    const { registry } = discoverAgents(cwd);
    90	    const discovered = registry.get("critic");
    91	    const base = discovered ?? FALLBACK_CRITIC;
    92	    return config.model ? { ...base, model: config.model } : base;
    93	  }
