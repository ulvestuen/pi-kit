   129	/**
   130	 * The stderr reported back to the runner for a finished job: the status
   131	 * line plus the child's captured stderr, so a failed sub-agent explains
   132	 * itself instead of surfacing as a bare exit code.
   133	 */
   134	async function reportStderr(
   135	  backend: SpawnBackend,
   136	  job: SpawnJob,
   137	): Promise<string> {
   138	  const base = statusStderr(job);
   139	  if (job.status === "done") return base;
   140	  let detail = "";
   141	  try {
   142	    detail = (await backend.errorOutput(job, ERROR_TAIL_BYTES)).trim();
   143	  } catch {
   144	    // Best-effort: the status line alone still reports the failure.
   145	  }
   146	  return detail ? `${base}\n${detail}` : base;
   147	}
   148	
   149	/**
   150	 * Kill/stamp stale internal synchronous jobs after a parent session restart.
   151	 *
   152	 * "Stale" means the recorded parent process is gone: this runs on every
   153	 * session_start, including inside spawned child pi processes (which load the
   154	 * same extensions) and in concurrently started sessions, so a running job
   155	 * whose parentPid is still alive is someone's live sub-agent — leave it
   156	 * alone. Jobs without a parentPid predate ownership tracking and are
   157	 * treated as stale, matching the old behavior.
   158	 */
   159	export async function cleanupSpawnToolingJobs(
   160	  options: CleanupSpawnToolingJobsOptions,
   161	): Promise<number> {
   162	  const now = options.now ?? Date.now;
   163	  const isParentAlive = options.isParentAlive ?? defaultIsParentAlive;
   164	  const prefix = `${options.jobNamePrefix}-`;
   165	  const jobs = loadJobs(options.config.logDir, options.onRegistryError);
   166	  let cleaned = 0;
   167	  let dirty = false;
   168	  for (const job of jobs) {
   169	    if (job.status !== "running" || !job.name.startsWith(prefix)) continue;
   170	    if (job.parentPid !== undefined && isParentAlive(job.parentPid)) continue;
   171	    const backend = options.backends[job.backend];
   172	    if (!backend) {
   173	      options.onError?.(
   174	        `could not clean stale spawn job ${job.name}: unknown backend ${job.backend}`,
   175	      );
   176	      continue;
   177	    }
   178	    try {
   179	      const kr = await backend.kill(job);
   180	      // KillResult branch 1 — stopped: backend confirmed the process is
   181	      // no longer running.  Stamp killed immediately.
   182	      if (kr.stopped) {
   183	        job.status = "killed";
   184	        job.updatedAt = now();
   185	        dirty = true;
   186	        cleaned++;
   187	      // KillResult branch 2 — alreadyComplete: backend says the process
   188	      // already exited before the kill.  Refresh from done marker to
   189	      // discover the real terminal status (done/failed).
   190	      } else if (kr.alreadyComplete) {
   191	        try {
   192	          await backend.refresh(job);
   193	        } catch {
   194	          // Best-effort.
   195	        }
   196	        if (!isTerminal(job.status)) {
   197	          // Backend confirmed completion but refresh could not resolve
   198	          // the status; mark lost so it does not stay "running" forever.
   199	          job.status = "lost";
   200	        }
   201	        job.updatedAt = now();
   202	        dirty = true;
   203	        cleaned++;
   204	      // KillResult branch 3 — warned / unconfirmed: kill signal sent but
   205	      // backend cannot confirm the process stopped.  Refresh from done
   206	      // markers; mark lost if still nonterminal.
   207	      } else {
   208	        try {
   209	          await backend.refresh(job);
   210	        } catch {
   211	          // Best-effort.
   212	        }
   213	        if (!isTerminal(job.status)) {
   214	          job.status = "lost";
   215	        }
   216	        job.updatedAt = now();
   217	        dirty = true;
   218	        cleaned++;
   219	        options.onError?.(
   220	          `could not kill stale spawn job ${job.name}: ${kr.message ?? "unknown"}`,
   221	        );
   222	      }
   223	    } catch (e: any) {
   224	      // Kill threw — equivalent to branch 3 (warned/unconfirmed).
   225	      // Mark lost so the job does not stay "running" forever.
   226	      if (!isTerminal(job.status)) {
   227	        job.status = "lost";
   228	      }
   229	      job.updatedAt = now();
   230	      dirty = true;
   231	      cleaned++;
   232	      options.onError?.(
   233	        `could not kill stale spawn job ${job.name}: ${e?.message ?? e}`,
   234	      );
   235	    }
   236	  }
   237	  if (dirty) saveJobs(options.config.logDir, jobs);
   238	  return cleaned;
   239	}
