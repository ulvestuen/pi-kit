   117	function statusExit(job: SpawnJob): number | null {
   118	  if (job.status === "done") return job.exitCode ?? 0;
   119	  if (job.status === "failed") return job.exitCode ?? 1;
   120	  return null;
   121	}
   122	
   123	function statusStderr(job: SpawnJob): string {
   124	  if (job.status === "done") return "";
   125	  const code = job.exitCode === undefined ? "" : ` (exit ${job.exitCode})`;
   126	  return `spawn job ${job.name} ended with status ${job.status}${code}`;
   127	}
