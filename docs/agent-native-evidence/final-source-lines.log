     1	/**
     2	 * critic review engine — pure, dependency-free prompt construction and
     3	 * output parsing for independent reviews.
     4	 *
     5	 * The only import is lykkja's pure loop engine, so scores land in lykkja's
     6	 * exact CriterionScore shape and can feed straight into lykkja_checkpoint.
     7	 * Robustness lives in parseCriticOutput: a review that cannot be parsed is a
     8	 * failed review, never a silent pass.
     9	 */
    10	
    11	import {
    12	  clampScore,
    13	  type Criterion,
    14	  type CriterionScore,
    15	} from "../lykkja/loop.ts";
    16	import type { ArtifactRef } from "@pi-kit/agent-types";
    17	
    18	export const DEFAULT_SCALE_MAX = 10;
    19	
    20	export interface ReviewRequest {
    21	  /** What is being reviewed: a diff, file list, artifact, or task result. */
    22	  subject: string;
    23	  /** Task brief, constraints — everything the critic needs to judge. */
    24	  context?: string;
    25	  /** The rubric — the same Criterion objects the planner attached to the task. */
    26	  criteria: Criterion[];
    27	  /** Top of the scoring scale. */
    28	  scaleMax: number;
    29	  /** Artifacts from prerequisite tasks or the implementer for evidence context. */
    30	  artifacts?: ArtifactRef[];
    31	}
    32	
    33	export interface ReviewResult {
    34	  /** lykkja-shaped: score + weakness per criterion. */
    35	  scores: CriterionScore[];
    36	  /** True only when every criterion met its threshold. */
    37	  passed: boolean;
    38	  /** Prioritized, actionable weaknesses (worst margin first). */
    39	  weaknesses: string[];
    40	  /** The critic's full prose, for the details view. */
    41	  raw: string;
    42	}
    43	
    44	export interface AdviseRequest {
    45	  /** The plan, approach, or design to critique before implementation. */
    46	  subject: string;
    47	  context?: string;
    48	}
    49	
    50	function validateRequest(req: ReviewRequest): void {
    51	  if (!req.subject?.trim()) {
    52	    throw new Error("Review subject must not be empty");
    53	  }
    54	  if (!Array.isArray(req.criteria) || req.criteria.length === 0) {
    55	    throw new Error("A review needs at least one criterion");
    56	  }
    57	  if (!Number.isFinite(req.scaleMax) || req.scaleMax < 2) {
    58	    throw new Error(`scaleMax must be at least 2 (got: ${req.scaleMax})`);
    59	  }
    60	}
    61	
    62	/** Turn a rubric into strict scoring instructions for the critic agent. */
    63	export function buildCriticPrompt(req: ReviewRequest): string {
    64	  validateRequest(req);
    65	  const rubric = req.criteria
    66	    .map((c) => `- "${c.name}" (passing threshold: ${c.threshold}/${req.scaleMax})`)
    67	    .join("\n");
    68	
    69	  return [
    70	    "Review the following subject against the rubric below. You are an independent critic: verify claims against the actual files with your read-only tools; never take the subject's description at face value.",
    71	    "",
    72	    "SUBJECT:",
    73	    req.subject.trim(),
    74	    ...(req.context?.trim() ? ["", "CONTEXT:", req.context.trim()] : []),
    75	    ...(req.artifacts && req.artifacts.length > 0
    76	      ? [
    77	          "",
    78	          "PREREQUISITE ARTIFACTS (for evidence context):",
    79	          ...req.artifacts.map((a) =>
    80	            `  - ${a.type}: ${a.description}${a.location ? ` at ${a.location}` : ""}`,
    81	          ),
    82	        ]
    83	      : []),
    84	    "",
    85	    "RUBRIC (score every criterion, integers 1.." + req.scaleMax + "):",
    86	    rubric,
    87	    "",
    88	    "Scoring rules:",
    89	    "- Score strictly from evidence you verified yourself. When in doubt, score lower.",
    90	    "- For every criterion below its threshold, give a precise, actionable weakness.",
    91	    "- Score every criterion in the rubric, by its exact name. Do not add criteria.",
    92	    "",
    93	    "After your analysis, output your verdict as exactly one fenced JSON block in this shape:",
    94	    "",
    95	    "```json",
    96	    JSON.stringify(
    97	      {
    98	        scores: [
    99	          { name: "<criterion name>", score: 0, weakness: "<required when below threshold>" },
   100	        ],
   101	      },
   102	      null,
   103	      2,
   104	    ),
   105	    "```",
   106	  ].join("\n");
   107	}
