===== FILE: spawn/backends/exedev.ts =====
     1	/**
     2	 * exe.dev backend — jobs run on a cloud VM instead of this machine.
     3	 *
     4	 * exe.dev's API is SSH (https://exe.dev/docs/api): `ssh exe.dev <command>`
     5	 * manages VMs (`new`, `ls --json`, `rm`), and `ssh <vm>.exe.xyz` is a full
     6	 * SSH connection into a VM. The default exeuntu image ships with `pi`
     7	 * preinstalled, so a job is: pipe a run script onto the VM over ssh, start
     8	 * it with setsid+nohup so it survives the connection, and poll its done
     9	 * marker and pid file — the remote twins of the local markers — over ssh.
    10	 *
    11	 * The backend reuses one VM (config.exedevVm) for all jobs, creating it on
    12	 * first use when allowed. It never deletes the VM: that is a billable,
    13	 * user-owned resource (`ssh exe.dev rm <vm>` when you are done with it).
    14	 */
    15	
    16	import { shellQuote } from "../../fleet/tmux.ts";
    17	import {
    18	  buildEnvExports,
    19	  buildPiShellCommand,
    20	  buildShellCommand,
    21	} from "../agent-command.ts";
    22	import type { SpawnConfig } from "../config.ts";
    23	import {
    24	  resolveStatus,
    25	  type ExecFn,
    26	  type LaunchRequest,
    27	  type SpawnBackend,
    28	  type SpawnJob,
    29	} from "../jobs.ts";
    30	import type { BackendCapabilities, KillResult } from "@pi-kit/agent-types";
    31	
    32	/** Lifecycle commands go to the exe.dev "lobby", not a VM. */
    33	export const EXEDEV_LOBBY = "exe.dev";
    34	
    35	const SSH_PROBE_TIMEOUT_MS = 30_000;
    36	const SSH_LAUNCH_TIMEOUT_MS = 60_000;
    37	const VM_CREATE_TIMEOUT_MS = 300_000;
    38	const VM_READY_TIMEOUT_MS = 180_000;
    39	const VM_READY_POLL_MS = 5_000;
    40	
    41	/** Job directory on the VM, relative to $HOME. */
    42	export function remoteJobDir(jobName: string): string {
    43	  return `.pi-spawn/${jobName}`;
    44	}
    45	
    46	/** Shell fragment resolving a job's absolute directory on the VM. */
    47	function remoteDirExpr(remoteDir: string): string {
    48	  return `"$HOME/"${shellQuote(remoteDir)}`;
    49	}
    50	
    51	/**
    52	 * The run script executed on the VM. It records its own pid (setsid makes
    53	 * it a session leader, so that pid also names the process group), runs pi
    54	 * from $HOME with output captured to the job log, and writes the exit code
    55	 * to the done marker.
    56	 *
    57	 * Like the other backends' scripts: stderr is captured to its own err.log
    58	 * so it never pollutes the parsed output stream, a cd failure explains
    59	 * itself in err.log before the done marker lands, and the exit code is
    60	 * staged and only published as the done marker after the log is fully
    61	 * written — a probe that sees the marker sees the complete log.
    62	 */
    63	export function buildRemoteRunScript(options: {
    64	  jobName: string;
    65	  piCommand: string;
    66	  remoteDir: string;
    67	  envExports: string[];
    68	  /** Optional cwd for prebuilt synchronous runner commands. */
    69	  cwd?: string;
    70	}): string {
    71	  const d = remoteDirExpr(options.remoteDir);
    72	  const cwd = options.cwd ? shellQuote(options.cwd) : '"$HOME"';
    73	  const cdFailed = options.cwd
    74	    ? shellQuote(
    75	        `[pi-spawn] could not cd to ${options.cwd} on the VM — the parent's working directory must exist there (see the spawn README's exe.dev notes)`,
    76	      )
    77	    : `'[pi-spawn] could not cd to $HOME on the VM'`;
    78	  return [
    79	    "#!/bin/sh",
    80	    `# pi-spawn job ${options.jobName}: one detached sub-agent on this VM.`,
    81	    `d=${d}`,
    82	    'echo $$ > "$d/pid"',
    83	    ...options.envExports,
    84	    `cd ${cwd} || { echo ${cdFailed} > "$d/err.log"; echo 127 > "$d/done"; exit 127; }`,
    85	    `{ ${options.piCommand}; echo $? > "$d/done.exit"; } > "$d/job.log" 2> "$d/err.log"`,
    86	    'mv "$d/done.exit" "$d/done"',
    87	    "",
    88	  ].join("\n");
    89	}
    90	
    91	/**
    92	 * The launch command run over ssh with the run script on stdin: store the
    93	 * script, then double-fork it into its own session so it survives both the
    94	 * ssh connection and any later SIGHUP.
    95	 */
    96	export function buildLaunchCommand(remoteDir: string): string {
    97	  const d = remoteDirExpr(remoteDir);
    98	  return [
    99	    `d=${d}`,
   100	    'mkdir -p "$d"',
   101	    'cat > "$d/run.sh"',
   102	    'chmod 700 "$d/run.sh"',
   103	    '(setsid nohup sh "$d/run.sh" > /dev/null 2>&1 &)',
   104	    "echo launched",
   105	  ].join(" && ");
   106	}
   107	
   108	/**
   109	 * One-round-trip status probe: prints `done:<exitcode>`, `running`, or
   110	 * `lost`. Distinguishing these from ssh/network failure matters — refresh
   111	 * must not mark a job lost just because the network blipped.
   112	 */
   113	export function buildProbeCommand(remoteDir: string): string {
   114	  const d = remoteDirExpr(remoteDir);
   115	  return (
   116	    `d=${d}; ` +
   117	    'if [ -s "$d/done" ]; then echo "done:$(cat "$d/done")"; ' +
   118	    'elif [ -s "$d/pid" ] && kill -0 "$(cat "$d/pid")" 2>/dev/null; then echo running; ' +
   119	    "else echo lost; fi"
   120	  );
   121	}
   122	
   123	/** Tail the remote job log; prints a placeholder when there is none yet. */
   124	export function buildTailCommand(remoteDir: string, maxBytes: number): string {
   125	  const d = remoteDirExpr(remoteDir);
   126	  if (!Number.isFinite(maxBytes)) {
   127	    return `d=${d}; cat "$d/job.log" 2>/dev/null || echo "(no output yet)"`;
   128	  }
   129	  return `d=${d}; tail -c ${Math.max(1, Math.floor(maxBytes))} "$d/job.log" 2>/dev/null || echo "(no output yet)"`;
   130	}
   131	
   132	/** Tail the remote stderr file; prints nothing when there is none. */
   133	export function buildErrTailCommand(
   134	  remoteDir: string,
   135	  maxBytes: number,
   136	): string {
   137	  const d = remoteDirExpr(remoteDir);
   138	  const read = Number.isFinite(maxBytes)
   139	    ? `tail -c ${Math.max(1, Math.floor(maxBytes))} "$d/err.log"`
   140	    : `cat "$d/err.log"`;
   141	  return `d=${d}; ${read} 2>/dev/null; true`;
   142	}
   143	
   144	/** SIGTERM the job's process group (setsid made pid == pgid). */
   145	export function buildKillCommand(remoteDir: string): string {
   146	  const d = remoteDirExpr(remoteDir);
   147	  return `d=${d}; if [ -s "$d/pid" ]; then kill -TERM -- "-$(cat "$d/pid")" 2>/dev/null || kill -TERM "$(cat "$d/pid")" 2>/dev/null; fi; true`;
   148	}
   149	
   150	/** Shape of `ssh exe.dev ls --json` (see https://exe.dev/docs/api). */
   151	export interface ExedevVmInfo {
   152	  vm_name: string;
   153	  ssh_dest?: string;
   154	  status?: string;
   155	}
   156	
   157	/** Parse `ssh exe.dev ls --json` output into its VM list. */
   158	export function parseVmList(stdout: string): ExedevVmInfo[] {
   159	  const parsed = JSON.parse(stdout);
   160	  const vms = Array.isArray(parsed) ? parsed : parsed?.vms;
   161	  if (!Array.isArray(vms)) {
   162	    throw new Error("unexpected `ssh exe.dev ls --json` output shape");
   163	  }
   164	  return vms.filter(
   165	    (vm: any): vm is ExedevVmInfo => typeof vm?.vm_name === "string",
   166	  );
   167	}
   168	
   169	export function createExedevBackend(
   170	  exec: ExecFn,
   171	  config: SpawnConfig,
   172	  options: { now?: () => number; sleep?: (ms: number) => Promise<void> } = {},
   173	): SpawnBackend {
   174	  const now = options.now ?? Date.now;
   175	  const sleep =
   176	    options.sleep ?? ((ms: number) => new Promise((r) => setTimeout(r, ms)));
   177	
   178	  const ssh = (
   179	    dest: string,
   180	    command: string,
   181	    opts: { stdin?: string; timeoutMs?: number } = {},
   182	  ) =>
   183	    exec(
   184	      config.sshBinary,
   185	      ["-o", "BatchMode=yes", dest, command],
   186	      { timeoutMs: SSH_PROBE_TIMEOUT_MS, ...opts },
   187	    );
   188	
   189	  const fallbackDest = () => `${config.exedevVm}.${config.exedevDomain}`;
   190	
   191	  /** Find or create the configured VM; returns its ssh destination. */
   192	  const ensureVm = async (): Promise<string> => {
   193	    const list = await ssh(EXEDEV_LOBBY, "ls --json");
   194	    if (list.exitCode !== 0) {
   195	      throw new Error(
   196	        `\`ssh exe.dev ls\` failed: ${list.stderr.trim() || "is your exe.dev SSH access set up? Try \`ssh exe.dev whoami\`"}`,
   197	      );
   198	    }
   199	    let vms: ExedevVmInfo[];
   200	    try {
   201	      vms = parseVmList(list.stdout);
   202	    } catch (e: any) {
   203	      throw new Error(`could not parse exe.dev VM list: ${e?.message ?? e}`);
   204	    }
   205	    const existing = vms.find((vm) => vm.vm_name === config.exedevVm);
   206	    if (existing) return existing.ssh_dest || fallbackDest();
   207	
   208	    if (!config.exedevAutoCreate) {
