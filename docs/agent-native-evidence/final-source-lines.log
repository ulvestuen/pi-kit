   339	        }
   340	
   341	        // --- Review everything now awaiting the critic --------------------
   342	        const reviewTargets = plan.tasks.filter((t) => t.status === "review");
   343	        const reviewsById = new Map<string, ReviewResult>();
   344	        if (reviewTargets.length > 0 && !signal?.aborted) {
   345	          progress(
   346	            `reviewing ${reviewTargets.length} task(s): ${reviewTargets.map((t) => t.id).join(", ")}`,
   347	          );
