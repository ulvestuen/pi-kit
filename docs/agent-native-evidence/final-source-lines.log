   570	        const data = entry.data as OrchestratorState | undefined;
   571	        if (data && typeof data.wave === "number") latest = data;
   572	      }
   573	    }
   574	    state = latest ?? { stopped: false, wave: 0 };
   575	  });
   576	
   577	  pi.registerCommand("orchestrate", {
   578	    description:
