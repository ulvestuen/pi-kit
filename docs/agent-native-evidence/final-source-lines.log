   109	/** Pre-implementation design feedback prompt — concerns, not scores. */
   110	export function buildAdvisePrompt(req: AdviseRequest): string {
   111	  if (!req.subject?.trim()) {
   112	    throw new Error("Advise subject must not be empty");
   113	  }
   114	  return [
   115	    "Give pre-implementation design feedback on the following plan or approach. You are an independent advisor with fresh context: inspect the repository with your read-only tools where the plan references it.",
   116	    "",
   117	    "SUBJECT:",
   118	    req.subject.trim(),
   119	    ...(req.context?.trim() ? ["", "CONTEXT:", req.context.trim()] : []),
   120	    "",
   121	    "Respond with:",
   122	    "1. A one-paragraph overall assessment.",
   123	    "2. A prioritized list of concerns (most important first). For each: what is at risk, why, and a concrete improvement.",
   124	    "3. Anything missing from the plan that is likely to bite.",
   125	    "",
   126	    "Do not implement anything and do not produce scores — concerns and recommendations only.",
   127	  ].join("\n");
   128	}
