   272	        // --- Dispatch the wave -------------------------------------------
   273	        state = { ...state, wave: state.wave + 1 };
   274	        persistState();
   275	        const wave = state.wave;
   276	        pi.events.emit("orchestrator:wave_start", {
   277	          wave,
   278	          dispatch: decision.dispatch.map((t) => t.id),
   279	        });
   280	
   281	        const dispatched = decision.dispatch;
   282	        for (const task of dispatched) {
   283	          plan = setPlanTaskRunning(plan, task.id);
   284	        }
   285	        publishPlan(plan);
   286	
   287	        const progress = (text: string) =>
   288	          onUpdate?.({
   289	            content: [{ type: "text", text: `wave ${wave}: ${text}` }],
   290	            details: { wave },
   291	          });
   292	
   293	        const scaleMax = DEFAULT_SCALE_MAX;
   294	        const resultsById = new Map<string, TaskResult>();
   295	        const runnerBase = {
   296	          spawn,
   297	          cwd: ctx.cwd,
   298	          piBinary: config.piBinary,
   299	          maxConcurrent: config.maxConcurrent,
   300	          outputCapBytes: config.outputCapBytes,
   301	          signal,
   302	          saveFullOutput: createFullOutputSaver("pi-orchestrator"),
   303	        };
   304	
   305	        if (dispatched.length > 0) {
   306	          progress(
   307	            `dispatching ${dispatched.length} task(s): ${dispatched.map((t) => t.id).join(", ")}`,
   308	          );
   309	          const specs: TaskSpec[] = dispatched.map((task) => ({
   310	            agent: task.agent ?? config.defaultAgent,
   311	            task: buildTaskBrief(plan!, task, scaleMax),
   312	            isolation: config.isolation,
   313	            timeoutMs: config.taskTimeoutMs,
   314	            parentBranch: config.isolation === "worktree"
   315	              ? findParentBranch(plan!, task)
   316	              : undefined,
   317	            runId: {
   318	              runId: `${task.id}-w${wave}-a${task.attempts + 1}`,
   319	              taskId: task.id,
   320	              attempt: task.attempts + 1,
   321	              wave,
   322	            },
   323	          }));
   324	          const results = await runTasks(registry, specs, {
   325	            ...runnerBase,
   326	            maxBatch: Math.max(specs.length, 1),
   327	            worktreeRoot:
   328	              config.isolation === "worktree"
   329	                ? createWorktreeRoot("pi-orchestrator")
   330	                : undefined,
   331	            onEvent: (e) => pi.events.emit(`fleet:${e.type}`, e),
   332	          });
   333	          results.forEach((result, i) => {
