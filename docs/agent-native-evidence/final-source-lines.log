   470	  it("refreshes from the pane and marker, and kills the window", async () => {
   471	    const config = testConfig();
   472	    let paneDead = false;
   473	    const { exec, calls } = fakeExec((call) => {
   474	      if (call.args[0] === "list-panes") {
   475	        return { stdout: paneDead ? "1\n" : "0\n" };
   476	      }
   477	      return {};
   478	    });
   479	    const backend = createTmuxBackend(exec, config);
   480	    const job = runningJob(config, { tmuxWindowId: "@7" });
   481	
   482	    assert.equal(await backend.refresh(job), false);
   483	    assert.equal(job.status, "running");
   484	
   485	    paneDead = true;
   486	    writeFileSync(job.donePath!, "2\n", "utf8");
   487	    assert.equal(await backend.refresh(job), true);
   488	    assert.equal(job.status, "failed");
   489	    assert.equal(job.exitCode, 2);
   490	
   491	    await backend.kill(job);
   492	    // With pane_dead=true, kill detects the pane is already gone
   493	    // and returns alreadyComplete without calling kill-window.
   494	    const killCalls = calls.filter((c) => c.args[0] === "kill-window");
   495	    assert.equal(killCalls.length, 0);
   496	
   497	    // When the pane is still alive, kill-window is called:
   498	    paneDead = false;
   499	    const job2 = runningJob(config, { tmuxWindowId: "@8" });
   500	    await backend.kill(job2);
   501	    const killCalls2 = calls.filter((c) => c.args[0] === "kill-window");
   502	    assert.deepEqual(killCalls2[killCalls2.length - 1]?.args, ["kill-window", "-t", "@8"]);
   503	  });
   504	});
