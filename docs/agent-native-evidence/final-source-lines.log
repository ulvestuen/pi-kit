    84	function buildTaskBrief(plan: Plan, task: PlanTask, scaleMax: number): string {
    85	  const criteria = task.criteria
    86	    .map((c) => `- ${c.name} (threshold ${c.threshold}/${scaleMax})`)
    87	    .join("\n");
    88	  const handoff = buildHandoffSection(plan, task);
    89	  return [
    90	    "You are executing one task of a larger orchestrated plan.",
    91	    "",
    92	    "OVERALL GOAL (context only — do not work beyond your task):",
    93	    plan.goal,
    94	    "",
    95	    `YOUR TASK (${task.id}): ${task.title}`,
    96	    task.description,
    97	    ...handoff ? [handoff] : [],
    98	    "",
    99	    "ACCEPTANCE CRITERIA — an independent critic will score each one afterwards:",
   100	    criteria,
   101	    "",
   102	    "Work only within this task's scope. End with a terse report: what changed (files touched), how a reviewer can verify each criterion, and any assumptions made.",
   103	  ].join("\n");
   104	}
   105	
   106	function buildReviewSubject(task: PlanTask, result?: TaskResult): string {
   107	  const lines = [`Task ${task.id}: ${task.title}`];
   108	  if (result?.output.trim()) {
   109	    lines.push("", "Implementer's report:", result.output.trim());
   110	  } else {
   111	    lines.push("", "No implementer report is available; verify from the tree alone.");
   112	  }
   113	  if (result?.branch) {
   114	    lines.push(
   115	      "",
   116	      `The work lives on branch ${result.branch}; you are running inside its worktree.`,
   117	    );
   118	  } else {
   119	    lines.push("", "The work is in the current working tree.");
   120	  }
   121	  if (result?.outputArtifacts && result.outputArtifacts.length > 0) {
   122	    lines.push("", "Implementer's output artifacts:");
   123	    for (const art of result.outputArtifacts)
   124	      lines.push(`  - ${art.type}: ${art.description}${art.location ? ` at ${art.location}` : ""}`);
   125	  }
   126	  if (task.artifacts.length > 0) {
   127	    lines.push("", "Recorded task artifacts:");
   128	    for (const art of task.artifacts)
   129	      lines.push(`  - ${art.type}: ${art.description}${art.location ? ` at ${art.location}` : ""}`);
   130	  }
   131	  return lines.join("\n");
   132	}
