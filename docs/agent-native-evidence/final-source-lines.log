  2205	      dirty = true;
  2206	      text = `Could not kill job "${foundJob.name}": ${kr.message ?? "unknown error"}.`;
  2207	    }
  2208	  }
  2209	  if (dirty) saveJobs(config.logDir, jobs);
  2210	  return { text, job: foundJob };
  2211	}
