    74	function testConfig(overrides: Partial<SpawnConfig> = {}): SpawnConfig {
    75	  return {
    76	    ...defaultConfig(),
    77	    logDir: mkdtempSync(path.join(os.tmpdir(), "pi-spawn-test-")),
    78	    ...overrides,
    79	  };
    80	}
