     1	/**
     2	 * Agent-native execution and result contracts for pi-kit.
     3	 *
     4	 * These types are the shared vocabulary between fleet, spawn, planner,
     5	 * orchestrator, and critic. They have zero runtime dependencies — only
     6	 * TypeScript interfaces and literal types — so every package in the
     7	 * workspace can depend on them without circular imports.
     8	 *
     9	 * Evolution rules: every interface has a `version` field. New fields
    10	 * append; old fields are never removed (marked `@deprecated` with a
    11	 * removal version instead). Old consumers see new optional fields as
    12	 * `undefined`.
    13	 */
    14	
    15	// ---------------------------------------------------------------------------
    16	// Identity
    17	// ---------------------------------------------------------------------------
    18	
    19	/** Unique stable identifier for an agent run across all layers. */
    20	export interface RunId {
    21	  /** Stable across the whole orchestration. */
    22	  runId: string;
    23	  /** Planner task id. */
    24	  taskId: string;
    25	  /** 1-based dispatch attempt. */
    26	  attempt: number;
    27	  /** Wave the task belongs to. */
    28	  wave: number;
    29	}
    30	
    31	// ---------------------------------------------------------------------------
    32	// Artifacts
    33	// ---------------------------------------------------------------------------
