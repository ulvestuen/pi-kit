   221	      if (job.hostPid !== undefined && detach.isPidAlive(job.hostPid)) {
   222	        return { stopped: false, message: "kill sent but host process still running" };
   223	      }
   224	      return { stopped: true };
   225	    },
   226	
   227	    async capabilities(): Promise<BackendCapabilities> {
   228	      return {
   229	        workspaceMount: config.msbMountCwd,
   230	        cursorOutput: false,
   231	        confirmedKill: false,
   232	        durableLogs: true,
   233	        networkAccess: true,
   234	        hardwareIsolation: true,
   235	      };
   236	    },
   237	  };
