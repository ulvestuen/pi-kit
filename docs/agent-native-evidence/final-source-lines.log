   238	describe("end-to-end simulation: 5-task DAG to FINAL", () => {
   239	  it("drives the plan to complete and the goal loop to FINAL", () => {
   240	    // Fake runner: t3 times out once; everything else succeeds first try.
   241	    const timeoutsLeft = new Map([["t3", 1]]);
   242	    const fakeRun = (taskId: string): TaskResult => {
   243	      const left = timeoutsLeft.get(taskId) ?? 0;
   244	      if (left > 0) {
   245	        timeoutsLeft.set(taskId, left - 1);
   246	        return okResult({ status: "timeout", output: "timed out" });
   247	      }
   248	      return okResult({ output: `${taskId} implemented` });
   249	    };
   250	    // Fake critic: fails t2's first review with an actionable weakness.
   251	    let t2Reviews = 0;
   252	    const fakeCritic = (taskId: string): ReviewResult => {
   253	      if (taskId === "t2" && t2Reviews++ === 0) {
   254	        return review(false, ["works: no test for empty input"]);
   255	      }
   256	      return review(true);
   257	    };
   258	
   259	    let plan = fiveTaskPlan();
   260	    const loop = createLoop({
   261	      task: "ship the feature",
   262	      criteria: ["all plan tasks done", "every task passed critic review"],
   263	      now: 1,
   264	    });
   265	
   266	    let verdict = "";
   267	    let waves = 0;
   268	    while (waves < 20) {
   269	      const decision = nextActions(plan, policy);
   270	      if (decision.terminal === "complete" || decision.terminal === "blocked") {
   271	        // Goal-level checkpoint from critic-derived evidence.
   272	        const summary = summarizePlan(plan);
   273	        const allDone = summary.done ? 10 : 3;
   274	        const { decision: act } = recordCheckpoint(loop, {
   275	          plan: `wave ${waves}: finish`,
   276	          changes: "final wave",
   277	          scores: [
   278	            { name: "all plan tasks done", score: allDone, weakness: summary.done ? undefined : "tasks remain" },
   279	            { name: "every task passed critic review", score: allDone, weakness: summary.done ? undefined : "reviews remain" },
   280	          ],
   281	        });
   282	        verdict = act.verdict;
   283	        break;
   284	      }
   285	
   286	      waves++;
   287	      // Dispatch wave.
   288	      for (const t of decision.dispatch) {
   289	        plan = setPlanTaskRunning(plan, t.id);
   290	        plan = applyTaskResult(plan, t.id, fakeRun(t.id), policy);
   291	      }
   292	      // Review wave.
   293	      for (const t of plan.tasks.filter((t) => t.status === "review")) {
   294	        plan = applyReview(plan, t.id, fakeCritic(t.id), policy);
   295	      }
   296	      // Mid-run checkpoint mirrors the orchestrate flow.
   297	      const summary = summarizePlan(plan);
   298	      const progress = Math.max(
   299	        1,
   300	        Math.round((summary.counts.done / summary.total) * 10),
   301	      );
   302	      const { decision: act } = recordCheckpoint(loop, {
   303	        plan: `wave ${waves}`,
   304	        changes: `done ${summary.counts.done}/${summary.total}`,
   305	        scores: [
   306	          {
   307	            name: "all plan tasks done",
   308	            score: summary.done ? 10 : Math.min(progress, 7),
   309	            weakness: summary.done ? undefined : "tasks remain",
   310	          },
   311	          {
   312	            name: "every task passed critic review",
   313	            score: summary.done ? 10 : Math.min(progress, 7),
   314	            weakness: summary.done ? undefined : "reviews remain",
   315	          },
   316	        ],
   317	      });
   318	      if (act.verdict !== "ITERATING") {
   319	        verdict = act.verdict;
   320	        break;
   321	      }
   322	    }
   323	
   324	    if (!verdict) {
   325	      const decision = nextActions(plan, policy);
   326	      assert.fail(`run did not terminate: ${decision.terminal} after ${waves} waves`);
   327	    }
   328	
   329	    const summary = summarizePlan(plan);
   330	    assert.strictEqual(summary.done, true, "every plan task is done");
   331	    assert.strictEqual(verdict, "FINAL");
   332	    // The retries actually happened: t3 needed 2 dispatch attempts,
   333	    // t2 needed 2 (one review failure), the rest 1.
   334	    assert.strictEqual(getTask(plan, "t3")!.attempts, 2);
   335	    assert.strictEqual(getTask(plan, "t2")!.attempts, 2);
   336	    assert.strictEqual(getTask(plan, "t1")!.attempts, 1);
   337	    assert.strictEqual(getTask(plan, "t4")!.attempts, 1);
   338	    assert.strictEqual(getTask(plan, "t5")!.attempts, 1);
   339	    // Critic feedback landed in the re-dispatched brief.
   340	    assert.match(getTask(plan, "t2")!.description, /no test for empty input/);
   341	    assert.strictEqual(loop.status, "final");
   342	  });
   343	
   344	  it("ends blocked and honest when a task exhausts its attempts", () => {
   345	    const strict: SchedulerPolicy = { maxConcurrent: 2, maxAttempts: 1 };
   346	    let plan = createPlan("g", [task("t1"), task("t2", { dependsOn: ["t1"] })]);
   347	
   348	    // t1 dispatches, fails review, and is out of attempts.
   349	    plan = setPlanTaskRunning(plan, "t1");
   350	    plan = applyTaskResult(plan, "t1", okResult(), strict);
   351	    plan = applyReview(plan, "t1", review(false, ["broken"]), strict);
   352	    assert.strictEqual(getTask(plan, "t1")!.status, "failed");
   353	
   354	    const decision = nextActions(plan, strict);
   355	    assert.strictEqual(decision.terminal, "blocked");
   356	    assert.deepStrictEqual(summarizePlan(plan).blocked, ["t2"]);
   357	  });
   358	});
