   131	/** Outcome of one short-lived helper process (tmux, ssh, msb). */
   132	export interface ExecOutcome {
   133	  /** Process exit code; null when it could not run or was killed. */
   134	  exitCode: number | null;
   135	  stdout: string;
   136	  stderr: string;
   137	}
