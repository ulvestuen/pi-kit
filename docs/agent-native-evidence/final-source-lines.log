     1	/**
     2	 * fleet runner — pure task-execution engine with injected effects.
     3	 *
     4	 * Owns process lifecycle, concurrency, timeouts, output handling, and
     5	 * isolation. It never imports pi or node:child_process — a spawn function is
     6	 * injected — so tests can drive it with fakes and other extensions can reuse
     7	 * it in any context.
     8	 */
     9	
    10	import { getAgent, type AgentDefinition } from "./registry.ts";
    11	import type { RunId, ArtifactRef } from "@pi-kit/agent-types";
    12	
    13	export const DEFAULT_MAX_CONCURRENT = 4;
    14	export const DEFAULT_MAX_BATCH = 8;
    15	export const DEFAULT_TIMEOUT_MS = 10 * 60 * 1000;
    16	export const DEFAULT_OUTPUT_CAP_BYTES = 50 * 1024;
    17	export const DEFAULT_PI_BINARY = "pi";
    18	
    19	/** One sub-agent task to run. */
    20	export interface TaskSpec {
    21	  /** Registry name of the agent definition to run under. */
    22	  agent: string;
    23	  /** The prompt/task text handed to the child agent. */
    24	  task: string;
    25	  /** Working directory; defaults to the runner's cwd. */
    26	  cwd?: string;
    27	  /** Working-tree isolation. Default "none". */
    28	  isolation?: "none" | "worktree";
    29	  /** Per-task timeout; defaults to the runner's defaultTimeoutMs. */
    30	  timeoutMs?: number;
    31	  /** Stable run identity across the orchestration (agent-native contract). */
    32	  runId?: RunId;
    33	  /** Artifacts available as input to this task. */
    34	  inputArtifacts?: ArtifactRef[];
    35	  /** Parent branch to create worktrees from (default: current HEAD). */
    36	  parentBranch?: string;
    37	}
    38	
    39	export type TaskStatus = "ok" | "error" | "timeout" | "aborted";
    40	
    41	export interface TaskResult {
    42	  agent: string;
    43	  status: TaskStatus;
    44	  /** Final assistant message (model-visible, capped at outputCapBytes). */
    45	  output: string;
    46	  /** Where the untruncated transcript landed, when a saver was provided. */
    47	  fullOutputPath?: string;
    48	  truncated: boolean;
    49	  durationMs: number;
    50	  exitCode?: number;
    51	  /** Task branch, when the task ran with worktree isolation. */
    52	  branch?: string;
    53	  /** Worktree path, when the task ran with worktree isolation. */
    54	  worktreePath?: string;
    55	  /** Stable run identity (agent-native contract). */
