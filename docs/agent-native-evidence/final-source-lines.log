   134	export default function (pi: ExtensionAPI) {
   135	  let config: OrchestratorConfig;
   136	  try {
   137	    config = loadConfig();
   138	  } catch (e: any) {
   139	    console.error(`[orchestrator] ${e.message}`);
   140	    console.error(
   141	      `[orchestrator] Using defaults. Fix ${getConfigPath()} or the ORCHESTRATOR_* env vars, then /reload.`,
   142	    );
   143	    config = {
   144	      maxConcurrent: 4,
   145	      maxAttempts: 2,
   146	      isolation: "none",
   147	      taskTimeoutMs: 10 * 60 * 1000,
   148	      reviewTimeoutMs: 5 * 60 * 1000,
   149	      outputCapBytes: 50 * 1024,
   150	      defaultAgent: "implementer",
   151	      piBinary: "pi",
   152	      tmux: true,
   153	      tmuxSession: DEFAULT_TMUX_SESSION,
   154	      tmuxCloseWindows: false,
   155	    };
   156	  }
   157	
   158	  const spawnConfig = loadHostSpawnConfig(config, "pi-orchestrator");
   159	  const spawnTmuxLive = spawnConfig.backend === "tmux" && isTmuxAvailable();
   160	  const spawn = createHostSpawn(config, "pi-orchestrator", spawnConfig);
   161	
   162	  const policy: SchedulerPolicy = {
   163	    maxConcurrent: config.maxConcurrent,
   164	    maxAttempts: config.maxAttempts,
   165	  };
   166	
   167	  let state: OrchestratorState = { stopped: false, wave: 0 };
   168	
   169	  const persistState = () => {
   170	    pi.appendEntry(STATE_ENTRY_TYPE, state);
   171	  };
   172	
   173	  /** Latest plan from the session entry log (planner's persisted state). */
   174	  const readPlan = (ctx: ExtensionContext): Plan | null => {
   175	    let latest: Plan | null = null;
   176	    for (const entry of ctx.sessionManager.getEntries()) {
   177	      if (entry.type === "custom" && entry.customType === PLAN_ENTRY_TYPE) {
   178	        const data = entry.data as Plan | undefined;
   179	        latest = data && typeof data.goal === "string" ? data : null;
   180	      }
   181	    }
   182	    return latest;
   183	  };
   184	
   185	  /** Hand the updated plan back to the planner extension via the shared bus. */
   186	  const publishPlan = (plan: Plan) => {
   187	    pi.events.emit("planner:set_plan", { plan });
   188	  };
   189	
   190	  const missingDependencies = (): string[] => {
   191	    const names = new Set(pi.getAllTools().map((t) => t.name));
   192	    return REQUIRED_TOOLS.filter((t) => !names.has(t));
   193	  };
   194	
   195	  pi.registerTool(
   196	    defineTool({
   197	      name: "orchestrate_step",
   198	      label: "orchestrator: Run Dispatch Wave",
   199	      description:
   200	        "Run one wave of the orchestration: dispatch the plan's ready tasks to fleet sub-agents in parallel, have an independent critic review each completed task against its own acceptance criteria, apply retries with critic feedback, and report the wave outcome. Requires an active plan (plan_create). Follow the AUTOMATED NEXT STEP in the result.",
   201	      promptSnippet:
   202	        "orchestrate_step: dispatch the ready plan tasks to sub-agents, review results with the critic, and report the wave.",
   203	      promptGuidelines: [
   204	        "During an orchestration run, call orchestrate_step for each wave and follow the AUTOMATED NEXT STEP in its result; do not implement plan tasks yourself.",
   205	      ],
   206	      parameters: Type.Object({}),
   207	      async execute(_id, _params, signal, onUpdate, ctx) {
   208	        if (state.stopped) {
   209	          return {
   210	            content: [
   211	              {
   212	                type: "text" as const,
   213	                text: "Orchestration stopped by user (/orchestrate stop). Do not dispatch further waves. Report the current plan state honestly and finish.",
   214	              },
   215	            ],
   216	            details: { stopped: true },
   217	          };
   218	        }
   219	
   220	        let plan = readPlan(ctx);
   221	        if (!plan) {
   222	          throw new Error(
   223	            "No active plan. Create one with plan_create before calling orchestrate_step.",
   224	          );
   225	        }
   226	
   227	        const { registry, errors: registryErrors } = discoverAgents(ctx.cwd);
   228	        const decision = nextActions(plan, policy);
   229	        const summaryBefore = summarizePlan(plan);
   230	
   231	        if (decision.terminal === "complete") {
   232	          return {
   233	            content: [
   234	              {
   235	                type: "text" as const,
   236	                text: [
   237	                  `All ${summaryBefore.total} plan tasks are done.`,
   238	                  "",
   239	                  "AUTOMATED NEXT STEP:",
   240	                  "1. Merge any unmerged task branches serially in DAG order (resolve trivial conflicts yourself; dispatch a fleet task for messy ones).",
   241	                  "2. Run the goal-level end-to-end verification.",
   242	                  "3. Call lykkja_checkpoint scoring every goal-level criterion honestly from that evidence.",
   243	                ].join("\n"),
   244	              },
   245	            ],
   246	            details: { terminal: "complete", summary: summaryBefore },
   247	          };
   248	        }
   249	
   250	        if (decision.terminal === "blocked") {
   251	          const failed = plan.tasks
   252	            .filter((t) => t.status === "failed")
   253	            .map((t) => t.id);
   254	          return {
   255	            content: [
   256	              {
   257	                type: "text" as const,
   258	                text: [
   259	                  `The plan is BLOCKED: failed task(s) [${failed.join(", ")}] hold back [${summaryBefore.blocked.join(", ") || "none"}], and nothing is dispatchable.`,
   260	                  "",
   261	                  "AUTOMATED NEXT STEP:",
   262	                  "1. Call lykkja_checkpoint scoring the goal-level criteria honestly (they cannot all pass while the DAG is blocked).",
   263	                  "2. On ITERATING: repair the plan with plan_update — append follow-up tasks that address the recorded weaknesses of the failed tasks (their briefs carry the critic feedback), or mark abandoned work failed and reduce scope explicitly.",
   264	                  "3. Then call orchestrate_step again. On STOPPED: report honestly which criteria still fail and why; nothing is silently discarded.",
   265	                ].join("\n"),
   266	              },
   267	            ],
   268	            details: { terminal: "blocked", failed, summary: summaryBefore },
   269	          };
   270	        }
