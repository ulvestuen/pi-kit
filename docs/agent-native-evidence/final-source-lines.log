   133	/** Build the pi CLI argument list for one child invocation.
   134	 *
   135	 * The child-process contract with pi's non-interactive mode is pinned here:
   136	 * `--mode json` selects single-shot print mode with a JSONL event stream,
   137	 * `--no-session` keeps children out of the session directory, and the agent
   138	 * definition supplies system prompt, model, thinking level, and tools.
   139	 */
   140	export function buildPiArgs(def: AgentDefinition, spec: TaskSpec): string[] {
   141	  const args = ["--mode", "json", "--no-session"];
   142	  args.push("--system-prompt", def.systemPrompt);
   143	  if (def.model) args.push("--model", def.model);
   144	  if (def.thinkingLevel) args.push("--thinking", def.thinkingLevel);
   145	  if (def.tools && def.tools.length > 0) {
   146	    args.push("--tools", def.tools.join(","));
   147	  }
   148	  args.push(spec.task);
   149	  return args;
   150	}
