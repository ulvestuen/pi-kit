   236	export function loadConfig(): SpawnConfig {
   237	  const { raw, configPath } = loadRawConfig();
   238	  const defaults = defaultConfig();
   239	
   240	  const outputTailBytes = parseNumber(
   241	    raw.outputTailBytes,
   242	    DEFAULT_OUTPUT_TAIL_BYTES,
   243	    "outputTailBytes",
   244	  );
   245	  if (outputTailBytes < 256) {
   246	    throw new Error(
   247	      `outputTailBytes must be at least 256 (got: ${outputTailBytes})`,
   248	    );
   249	  }
   250	
   251	  const msbCpus =
   252	    raw.msbCpus === undefined || raw.msbCpus === ""
   253	      ? undefined
   254	      : parseNumber(raw.msbCpus, 0, "msbCpus");
   255	  if (msbCpus !== undefined && msbCpus < 1) {
   256	    throw new Error(`msbCpus must be at least 1 (got: ${msbCpus})`);
   257	  }
   258	
   259	  return {
   260	    backend: parseBackend(raw.backend),
   261	    logDir: raw.logDir?.trim() || defaults.logDir,
   262	    piBinary: raw.piBinary?.trim() || defaults.piBinary,
   263	    outputTailBytes: Math.round(outputTailBytes),
   264	    injectSystemPrompt: parseBoolean(raw.injectSystemPrompt, true),
   265	    envPassthrough: parseStringList(
   266	      raw.envPassthrough,
   267	      defaults.envPassthrough,
   268	    ),
   269	    sshBinary: raw.sshBinary?.trim() || defaults.sshBinary,
   270	    tmuxSession: raw.tmuxSession?.trim() || defaults.tmuxSession,
   271	    tmuxForwardEnv: parseBoolean(raw.tmuxForwardEnv, true),
   272	    exedevVm: raw.exedevVm?.trim() || defaults.exedevVm,
   273	    exedevDomain: raw.exedevDomain?.trim() || defaults.exedevDomain,
   274	    exedevAutoCreate: parseBoolean(raw.exedevAutoCreate, true),
   275	    exedevForwardEnv: parseBoolean(raw.exedevForwardEnv, false),
   276	    msbBinary: raw.msbBinary?.trim() || defaults.msbBinary,
   277	    msbImage: raw.msbImage?.trim() || defaults.msbImage,
   278	    msbMountCwd: parseBoolean(raw.msbMountCwd, true),
   279	    msbForwardEnv: parseBoolean(raw.msbForwardEnv, true),
   280	    msbRemoveSandbox: parseBoolean(raw.msbRemoveSandbox, true),
   281	    msbCpus: msbCpus === undefined ? undefined : Math.round(msbCpus),
