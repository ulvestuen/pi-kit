   607	        ];
   608	        if (!raw) {
   609	          lines.push("  Usage: /orchestrate <goal> | status | stop");
   610	        }
   611	        ctx.ui.notify(lines.join("\n"), "info");
   612	        return;
   613	      }
   614	
   615	      if (word === "stop") {
   616	        state = { ...state, stopped: true };
   617	        persistState();
   618	        ctx.ui.notify(
   619	          "Orchestration will halt: the next orchestrate_step reports the stop instead of dispatching.",
   620	          "info",
   621	        );
   622	        return;
   623	      }
   624	
   625	      const missing = missingDependencies();
   626	      if (missing.length > 0) {
   627	        ctx.ui.notify(
   628	          `Cannot orchestrate — missing tools: ${missing.join(", ")}. Install the lykkja and planner packages (pi-kit ships both), then /reload.`,
   629	          "error",
   630	        );
   631	        return;
   632	      }
   633	
   634	      state = { stopped: false, wave: 0 };
   635	      persistState();
   636	      pi.sendUserMessage(buildRunPrompt(raw));
   637	    },
   638	  });
   639	}
