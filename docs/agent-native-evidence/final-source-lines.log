===== FILE: spawn/jobs.ts =====
     1	/**
     2	 * spawn job model — detached sub-agent jobs and their persistent registry.
     3	 *
     4	 * A job is one `pi` sub-agent run launched *detached* on a backend (a tmux
     5	 * window, an exe.dev cloud VM, or a microsandbox microVM). Unlike fleet
     6	 * tasks, jobs outlive the tool call — and the pi session — that started
     7	 * them, so their state lives in two places the parent process does not own:
     8	 *
     9	 *  - a **done marker**: a file the job's run script writes its exit code to
    10	 *    when the pi child finishes (locally for tmux/microsandbox, on the VM
    11	 *    for exe.dev), and
    12	 *  - a **job registry**: a JSON file under the spawn log directory that
    13	 *    records every launched job so any later session can find it again.
    14	 *
    15	 * Status is always *derived*: done marker present → done/failed by exit
    16	 * code; no marker but the runner is alive → running; no marker and no
    17	 * runner → lost. Only "killed" is stamped directly, by spawn_kill.
    18	 */
    19	
    20	import { mkdirSync, readFileSync, renameSync, writeFileSync } from "node:fs";
    21	import * as path from "node:path";
    22	import type { AgentDefinition } from "../fleet/registry.ts";
    23	import type { BackendCapabilities, KillResult } from "@pi-kit/agent-types";
    24	
    25	export type SpawnBackendName = "tmux" | "exedev" | "microsandbox";
    26	
    27	export const SPAWN_BACKEND_NAMES: SpawnBackendName[] = [
    28	  "tmux",
    29	  "exedev",
    30	  "microsandbox",
    31	];
    32	
    33	export type SpawnJobStatus =
    34	  | "running"
    35	  | "done"
    36	  | "failed"
    37	  | "killed"
    38	  | "lost";
    39	
    40	/** One detached sub-agent job. */
    41	export interface SpawnJob {
    42	  /** Unique job name; also the job's directory name under logDir. */
    43	  name: string;
    44	  backend: SpawnBackendName;
    45	  /** Agent registry name the job runs under. */
    46	  agent: string;
    47	  /** The task brief handed to the pi child. */
    48	  task: string;
    49	  /** Working directory the job was launched from. */
    50	  cwd: string;
    51	  status: SpawnJobStatus;
    52	  exitCode?: number;
    53	  createdAt: number;
    54	  updatedAt: number;
    55	  /**
    56	   * Pid of the pi session process that launched this job, recorded only for
    57	   * internal synchronous runner jobs (fleet/critic/orchestrator children).
    58	   * Session-start cleanup treats a running internal job as stale only when
    59	   * this process is gone — a spawned child pi loads the same extensions and
    60	   * must not kill the jobs of a parent that is still alive (itself included).
    61	   */
    62	  parentPid?: number;
    63	  /** Local log file (tmux and microsandbox backends). */
    64	  logPath?: string;
    65	  /** Local done marker (tmux and microsandbox backends). */
    66	  donePath?: string;
    67	  /** Local stderr file (tmux and microsandbox backends). */
    68	  errPath?: string;
    69	  /** tmux window id (e.g. "@42") holding the job (tmux backend). */
    70	  tmuxWindowId?: string;
    71	  /** Host pid of the detached `msb run` process (microsandbox backend). */
    72	  hostPid?: number;
    73	  /** microsandbox sandbox name (microsandbox backend). */
    74	  sandboxName?: string;
    75	  /** exe.dev VM name (exedev backend). */
    76	  vmName?: string;
    77	  /** SSH destination of the VM, e.g. "pi-spawn.exe.xyz" (exedev backend). */
    78	  sshDest?: string;
    79	  /** Job directory on the VM, relative to $HOME (exedev backend). */
    80	  remoteDir?: string;
    81	}
    82	
    83	/** Statuses that never change again; refresh skips jobs in these. */
    84	export function isTerminal(status: SpawnJobStatus): boolean {
    85	  return status !== "running";
    86	}
    87	
    88	/**
    89	 * Derive a job's status from its done marker and a runner-aliveness probe.
    90	 * The probe is only meaningful when no marker exists yet; callers pass
    91	 * alive=false alongside a marker (see refreshFromLocalMarkers).
    92	 */
    93	export function resolveStatus(
    94	  doneContent: string | undefined,
    95	  alive: boolean,
    96	): { status: SpawnJobStatus; exitCode?: number } {
    97	  if (doneContent !== undefined) {
    98	    const parsed = Number.parseInt(doneContent.trim(), 10);
    99	    const exitCode = Number.isNaN(parsed) ? undefined : parsed;
   100	    return { status: exitCode === 0 ? "done" : "failed", exitCode };
   101	  }
   102	  return alive ? { status: "running" } : { status: "lost" };
   103	}
   104	
   105	/** Job names double as directory, tmux window, and sandbox names. */
   106	export function sanitizeJobName(name: string): string {
   107	  const cleaned = name
   108	    .replace(/[^a-zA-Z0-9_-]+/g, "-")
   109	    .replace(/^-+|-+$/g, "")
   110	    .slice(0, 48);
   111	  return cleaned || "job";
   112	}
   113	
   114	/**
   115	 * Derive a unique job name: the requested (or agent-derived) base plus a
   116	 * timestamp suffix, with a counter appended on the rare collision.
   117	 */
   118	export function uniqueJobName(
   119	  base: string,
   120	  taken: (name: string) => boolean,
   121	  now: number,
   122	): string {
   123	  const root = `${sanitizeJobName(base)}-${now.toString(36)}`;
   124	  if (!taken(root)) return root;
   125	  for (let i = 2; ; i++) {
   126	    const candidate = `${root}-${i}`;
   127	    if (!taken(candidate)) return candidate;
   128	  }
   129	}
