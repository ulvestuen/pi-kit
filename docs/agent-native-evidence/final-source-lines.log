   153	/** Effects for backends that keep a detached runner process on this host. */
   154	export interface DetachEffects {
   155	  /** Start a fully detached process; returns its pid. Throws on failure. */
   156	  spawnDetached(command: string, args: string[]): number;
   157	  /** Whether a pid still exists. */
   158	  isPidAlive(pid: number): boolean;
