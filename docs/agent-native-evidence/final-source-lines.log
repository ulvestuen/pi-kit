    42	
    43	// ---------------------------------------------------------------------------
    44	// Task / Result contracts
    45	// ---------------------------------------------------------------------------
    46	
    47	/** Structured input contract for an agent execution. */
    48	export interface AgentTask {
    49	  /** Schema version; starts at 1. */
    50	  version: number;
    51	  runId: RunId;
    52	  role: string;
    53	  prompt: string;
    54	  inputArtifacts: ArtifactRef[];
    55	  parentRuns: RunId[];
    56	  constraints: {
    57	    timeoutMs?: number;
    58	    outputCapBytes?: number;
    59	    isolation?: "none" | "worktree";
    60	    cwd?: string;
    61	  };
    62	}
    63	
    64	/** Structured result produced by an agent execution. */
    65	export interface AgentResult {
    66	  /** Schema version. */
    67	  version: number;
    68	  runId: RunId;
    69	  status: "ok" | "error" | "timeout" | "aborted";
    70	  output: string;
    71	  outputArtifacts: ArtifactRef[];
    72	  toolCalls: ToolCallSummary[];
    73	  usage?: {
    74	    promptTokens?: number;
    75	    completionTokens?: number;
    76	  };
    77	  durationMs: number;
    78	  exitCode: number | null;
    79	  fullTranscriptPath?: string;
    80	  truncated: boolean;
    81	}
    82	
    83	/** Summary of one tool call made during execution. */
    84	export interface ToolCallSummary {
