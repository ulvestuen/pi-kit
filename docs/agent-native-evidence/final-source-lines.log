  1416	describe("runner-adapter kill/cancellation semantics", () => {
  1417	  it("kill alreadyComplete does NOT stamp 'killed' in the adapter", async () => {
  1418	    const config = testConfig();
  1419	    const { backend } = backendForAdapter(config);
  1420	    // Override kill to return alreadyComplete.
  1421	    let killAttempted = false;
  1422	    backend.kill = async () => {
  1423	      killAttempted = true;
  1424	      return { stopped: false, alreadyComplete: true, message: "process already exited" };
  1425	    };
  1426	    // Override refresh: keep running until abort fires, then resolve to done.
  1427	    let aborted = false;
  1428	    backend.refresh = async (job) => {
  1429	      if (aborted && job.status === "running") {
  1430	        job.status = "done";
  1431	        job.exitCode = 0;
  1432	        job.updatedAt = Date.now();
  1433	        return true;
  1434	      }
  1435	      return false;
  1436	    };
  1437	    const controller = new AbortController();
  1438	    const spawn = createSpawnToolingSpawn({
  1439	      config,
  1440	      backends: { tmux: backend, exedev: backend, microsandbox: backend },
  1441	      pollIntervalMs: 1,
  1442	      sleep: async () => {
  1443	        if (!aborted) {
  1444	          aborted = true;
  1445	          controller.abort();
  1446	        }
  1447	      },
  1448	    });
  1449	    const outcome = await spawn({
  1450	      command: "pi",
  1451	      args: ["task"],
  1452	      cwd: "/repo",
  1453	      signal: controller.signal,
  1454	      label: "1-scout",
  1455	    });
  1456	    // The kill was attempted but the backend said alreadyComplete.
  1457	    assert.equal(killAttempted, true);
  1458	    // The job should NOT be stamped "killed" — it keeps its original
  1459	    // terminal status from the refresh ("done").
  1460	    const [job] = loadJobs(config.logDir);
  1461	    assert.notEqual(job.status, "killed");
  1462	  });
  1463	
