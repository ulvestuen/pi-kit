     1	/**
     2	 * orchestrator handoff — pure helper functions for artifact propagation,
     3	 * prerequisite branch extraction, and worktree commit coordination.
     4	 *
     5	 * Only depends on planner/plan.ts types and @pi-kit/agent-types, so it
     6	 * can be unit-tested in isolation without the pi extension host.
     7	 */
     8	
     9	import type { ArtifactRef } from "@pi-kit/agent-types";
    10	import type { TaskResult } from "../fleet/runner.ts";
    11	import {
    12	  getTask,
    13	  updateTask,
    14	  type Plan,
    15	  type PlanTask,
    16	} from "../planner/plan.ts";
    17	
    18	/**
    19	 * Build a brief section listing prerequisite artifacts from done dependencies.
    20	 * Injected into the downstream task's brief so structured artifact handoff
    21	 * happens through the brief text — no shared conversation context needed.
    22	 */
    23	export function buildHandoffSection(plan: Plan, task: PlanTask): string {
    24	  const deps = task.dependsOn
    25	    .map((id) => getTask(plan, id))
    26	    .filter((t): t is PlanTask =>
    27	      t !== undefined && t.status === "done" && t.artifacts.length > 0,
    28	    );
    29	  if (deps.length === 0) return "";
    30	  const lines = ["", "Prerequisite artifacts:"];
    31	  for (const dep of deps) {
    32	    lines.push(`  [${dep.id}] ${dep.title}:`);
    33	    for (const art of dep.artifacts)
    34	      lines.push(
    35	        `    - ${art.type}: ${art.description} at ${art.location ?? "(in-tree)"}`,
    36	      );
    37	  }
    38	  return lines.join("\n");
    39	}
    40	
    41	/**
    42	 * Extract the parent branch from prerequisite task branch artifacts.
    43	 * Used by the orchestrator to create worktrees forked from the prerequisite
    44	 * branch instead of HEAD — enabling prerequisite branch handoff.
    45	 */
    46	export function findParentBranch(
    47	  plan: Plan,
    48	  task: PlanTask,
    49	): string | undefined {
    50	  for (const depId of task.dependsOn) {
    51	    const dep = getTask(plan, depId);
    52	    if (dep && dep.status === "done") {
    53	      const branchArt = dep.artifacts.find((a) => a.type === "branch");
    54	      if (branchArt) return branchArt.location ?? branchArt.id;
    55	    }
    56	  }
    57	  return undefined;
    58	}
    59	
    60	/**
    61	 * When a task passes review, record its output artifacts in the plan.
    62	 * In worktree mode, commit the implementer's changes first via the
    63	 * optional worktreeCommit callback (best-effort; errors are swallowed).
    64	 */
    65	export async function recordPassingArtifacts(
    66	  plan: Plan,
    67	  task: PlanTask,
    68	  result?: TaskResult,
    69	  worktreeCommit?: (branch: string) => Promise<void>,
    70	): Promise<Plan> {
    71	  const artifacts: ArtifactRef[] = [];
    72	  if (result?.branch) {
    73	    artifacts.push({
    74	      type: "branch",
    75	      id: result.branch,
    76	      description: `Branch ${result.branch} with completed changes`,
    77	      location: result.branch,
    78	    });
    79	  }
    80	  if (result?.worktreePath) {
    81	    artifacts.push({
    82	      type: "path",
    83	      id: `${task.id}-worktree`,
    84	      description: `Worktree path for task ${task.id}`,
    85	      location: result.worktreePath,
    86	    });
    87	  }
    88	  if (result?.outputArtifacts) {
    89	    artifacts.push(...result.outputArtifacts);
    90	  }
    91	  if (result?.fullOutputPath) {
    92	    artifacts.push({
    93	      type: "path",
    94	      id: `${task.id}-transcript`,
    95	      description: `Full transcript for task ${task.id}`,
    96	      location: result.fullOutputPath,
    97	    });
    98	  }
    99	  // Always add a summary artifact
   100	  artifacts.push({
   101	    type: "summary",
   102	    id: `${task.id}-summary`,
   103	    description: `Summary of task ${task.id}: ${task.title}`,
   104	  });
   105	
   106	  let updated = updateTask(plan, task.id, { artifacts });
   107	  if (worktreeCommit && result?.branch) {
   108	    // Commit is best-effort — artifact recording is the important part.
   109	    try {
   110	      await worktreeCommit(result.branch);
   111	    } catch {
   112	      // Swallow: commit failure does not block plan progression.
   113	    }
   114	  }
   115	  return updated;
   116	}
