  1109	  const ENV_KEYS = [
  1110	    "SPAWN_CONFIG_PATH",
  1111	    "SPAWN_BACKEND",
  1112	    "SPAWN_LOG_DIR",
  1113	    "SPAWN_MSB_IMAGE",
  1114	  ];
  1115	
  1116	  function withEnv(env: Record<string, string>, fn: () => void): void {
  1117	    const saved = ENV_KEYS.map((k) => [k, process.env[k]] as const);
  1118	    for (const key of ENV_KEYS) delete process.env[key];
  1119	    Object.assign(process.env, env);
  1120	    try {
  1121	      fn();
  1122	    } finally {
  1123	      for (const [key, value] of saved) {
  1124	        if (value === undefined) delete process.env[key];
  1125	        else process.env[key] = value;
  1126	      }
  1127	    }
  1128	  }
