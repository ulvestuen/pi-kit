    54	/** Restore the most recent loop state from the session entry log.
    55	 * When a tombstone (reset marker) is encountered, all prior entries
    56	 * are invalidated — the loop was explicitly cleared. */
    57	function restoreState(ctx: ExtensionContext): LoopState | null {
    58	  let latest: LoopState | null = null;
    59	  for (const entry of ctx.sessionManager.getEntries()) {
    60	    if (entry.type === "custom" && entry.customType === STATE_ENTRY_TYPE) {
    61	      const data = entry.data as LoopState | TombstoneEntry | undefined;
    62	      if (isTombstone(data)) {
    63	        // Reset marker — discard everything seen so far
    64	        latest = null;
    65	      } else if (data && typeof data.task === "string") {
    66	        latest = data;
    67	      }
    68	    }
    69	  }
    70	  return latest;
    71	}
