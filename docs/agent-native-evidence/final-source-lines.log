   102	function runningJob(
   103	  config: SpawnConfig,
   104	  overrides: Partial<SpawnJob> = {},
   105	): SpawnJob {
   106	  const job: SpawnJob = {
   107	    name: "job-a",
   108	    backend: "tmux",
   109	    agent: "scout",
   110	    task: "look around",
   111	    cwd: "/tmp",
   112	    status: "running",
   113	    createdAt: 1000,
   114	    updatedAt: 1000,
   115	    ...overrides,
   116	  };
   117	  const dir = localJobDir(job, config);
   118	  mkdirSync(dir, { recursive: true });
   119	  job.logPath = job.logPath ?? path.join(dir, "job.log");
   120	  job.donePath = job.donePath ?? path.join(dir, "done");
   121	  job.errPath = job.errPath ?? path.join(dir, "err.log");
   122	  return job;
   123	}
