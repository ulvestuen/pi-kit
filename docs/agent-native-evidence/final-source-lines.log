   280	    }),
   281	  );
   282	
   283	  // Loose extension-to-extension composition: the orchestrator applies
   284	  // scheduler results by emitting the whole updated plan on the shared bus.
   285	  pi.events.on("planner:set_plan", (data) => {
   286	    const incoming = (data as { plan?: Plan } | undefined)?.plan;
   287	    if (!incoming || typeof incoming.goal !== "string") return;
   288	    plan = incoming;
   289	    persist();
   290	  });
   291	
   292	  pi.on("before_agent_start", async (event) => {
   293	    if (!config.injectSystemPrompt) return;
   294	    return {
   295	      systemPrompt: `${event.systemPrompt}\n\n${buildSystemPrompt(config)}`,
   296	    };
   297	  });
   298	
   299	  pi.on("session_start", async (_event, ctx) => {
   300	    plan = restoreState(ctx);
   301	    // Children do not survive a restart: reset in-flight work so the next
   302	    // scheduling pass re-dispatches it idempotently.
   303	    if (plan) {
   304	      let changed = false;
   305	      for (const task of plan.tasks) {
   306	        if (task.status === "running") {
   307	          plan = setTaskStatus(plan, task.id, "ready");
   308	          changed = true;
   309	        }
   310	      }
   311	      if (changed) persist();
   312	    }
   313	    updateStatus(ctx);
   314	  });
   315	
   316	  pi.registerCommand("plan", {
   317	    description:
   318	      "Plan dashboard. Args: (none) show the DAG and progress, 'reset' clear the plan.",
   319	    getArgumentCompletions: (prefix) => {
   320	      const subcommands = [{ value: "reset", label: "reset — clear the plan" }];
   321	      const matches = subcommands.filter((s) => s.value.startsWith(prefix.toLowerCase()));
   322	      return matches.length > 0 ? matches : null;
   323	    },
   324	    handler: async (args, ctx) => {
   325	      const raw = args.trim().toLowerCase();
   326	      if (raw === "reset" || raw === "clear") {
   327	        plan = null;
   328	        persist();
   329	        updateStatus(ctx);
   330	        ctx.ui.notify("Plan cleared.", "info");
   331	        return;
   332	      }
   333	      if (!plan) {
   334	        ctx.ui.notify(
   335	          "No active plan. Ask the agent to create one with plan_create, or /orchestrate a goal.",
   336	          "info",
   337	        );
   338	        return;
   339	      }
   340	      ctx.ui.notify(renderDashboard(plan), "info");
   341	    },
   342	  });
   343	}
