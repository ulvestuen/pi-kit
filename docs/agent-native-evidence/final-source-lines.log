   163	/** What a backend needs to launch one job. */
   164	export interface LaunchRequest {
   165	  jobName: string;
   166	  agent: AgentDefinition;
   167	  task: string;
   168	  cwd: string;
   169	  /**
   170	   * Optional prebuilt command for internal synchronous runner jobs.
   171	   * When omitted, backends build the normal spawn_agent `pi -p` invocation
   172	   * from agent + task.
   173	   */
   174	  command?: string;
   175	  args?: string[];
   176	}
   177	
   178	/**
   179	 * One spawn backend: a place detached sub-agent jobs run.
   180	 *
   181	 * launch() starts the job and returns its initial record; refresh() updates
   182	 * status/exitCode from the backend's markers and returns whether anything
   183	 * changed (callers skip terminal jobs); output() reads a log tail;
   184	 * errorOutput() reads the job's captured stderr ("" when there is none);
   185	 * kill() best-effort stops the runner — the caller stamps status "killed".
   186	 */
   187	export interface SpawnBackend {
   188	  readonly name: SpawnBackendName;
   189	  /** Undefined when usable; otherwise a human-readable reason it is not. */
   190	  available(): Promise<string | undefined>;
   191	  launch(request: LaunchRequest): Promise<SpawnJob>;
   192	  refresh(job: SpawnJob): Promise<boolean>;
   193	  output(job: SpawnJob, maxBytes: number): Promise<string>;
   194	  errorOutput(job: SpawnJob, maxBytes: number): Promise<string>;
   195	  /** Best-effort stop. Returns KillResult confirming whether the stop succeeded. */
   196	  kill(job: SpawnJob): Promise<KillResult>;
   197	  /** Declares this backend's capabilities for contract negotiation. */
   198	  capabilities(): Promise<BackendCapabilities>;
   199	}
