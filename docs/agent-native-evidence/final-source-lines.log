    38	export interface PlanTask {
    39	  id: string;
    40	  title: string;
    41	  /** Full brief handed to the sub-agent. */
    42	  description: string;
    43	  /** Ids of tasks that must be done before this one can run. */
    44	  dependsOn: string[];
    45	  /** fleet agent name; defaults to "implementer". */
    46	  agent?: string;
    47	  /** lykkja-shaped acceptance criteria. */
    48	  criteria: Criterion[];
    49	  status: TaskStatus;
    50	  /** Number of times the task has been dispatched. */
    51	  attempts: number;
    52	  /** Artifacts produced by this task after passing review. */
    53	  artifacts: ArtifactRef[];
    54	}
    55	
    56	export interface Plan {
    57	  goal: string;
    58	  tasks: PlanTask[];
    59	  createdAt: number;
    60	  updatedAt: number;
    61	}
    62	
    63	export interface PlanTaskInput {
    64	  id: string;
    65	  title: string;
    66	  description: string;
    67	  dependsOn?: string[];
    68	  agent?: string;
    69	  criteria: CriterionInput[];
    70	}
    71	
    72	export interface CreatePlanOptions {
    73	  passThreshold?: number;
    74	  scaleMax?: number;
    75	  now?: number;
    76	}
    77	
    78	function normalizeId(id: string): string {
    79	  return id.trim();
    80	}
    81	
    82	function idKey(id: string): string {
    83	  return normalizeId(id).toLowerCase();
    84	}
    85	
    86	function buildTask(
    87	  input: PlanTaskInput,
    88	  options: CreatePlanOptions,
    89	): PlanTask {
    90	  const id = normalizeId(input.id ?? "");
    91	  if (!id) {
    92	    throw new Error("Every task needs a non-empty id");
    93	  }
    94	  const title = (input.title ?? "").trim();
    95	  if (!title) {
    96	    throw new Error(`Task "${id}" needs a non-empty title`);
    97	  }
    98	  const description = (input.description ?? "").trim();
    99	  if (!description) {
   100	    throw new Error(`Task "${id}" needs a non-empty description`);
   101	  }
   102	  const criteria = normalizeCriteria(
   103	    input.criteria ?? [],
   104	    options.passThreshold ?? DEFAULT_PASS_THRESHOLD,
   105	    options.scaleMax ?? DEFAULT_SCALE_MAX,
   106	  );
   107	  return {
   108	    id,
   109	    title,
   110	    description,
   111	    dependsOn: (input.dependsOn ?? []).map(normalizeId).filter(Boolean),
   112	    agent: input.agent?.trim() || undefined,
   113	    criteria,
   114	    status: "pending",
   115	    attempts: 0,
   116	    artifacts: [],
   117	  };
   118	}
   119	
   120	/** Validate the task list as a DAG: unique ids, no dangling deps, no cycles. */
   121	function validateDag(tasks: PlanTask[]): void {
   122	  const byId = new Map<string, PlanTask>();
   123	  for (const task of tasks) {
   124	    const key = idKey(task.id);
   125	    if (byId.has(key)) {
   126	      throw new Error(`Duplicate task id: ${task.id}`);
   127	    }
   128	    byId.set(key, task);
   129	  }
   130	
   131	  for (const task of tasks) {
   132	    for (const dep of task.dependsOn) {
   133	      if (idKey(dep) === idKey(task.id)) {
   134	        throw new Error(`Task "${task.id}" depends on itself`);
   135	      }
   136	      if (!byId.has(idKey(dep))) {
   137	        throw new Error(
   138	          `Task "${task.id}" depends on unknown task "${dep}"`,
   139	        );
   140	      }
   141	    }
   142	  }
   143	
   144	  // Kahn's algorithm: if not every task can be ordered, there is a cycle.
   145	  const indegree = new Map<string, number>();
   146	  const dependents = new Map<string, string[]>();
   147	  for (const task of tasks) {
   148	    indegree.set(idKey(task.id), task.dependsOn.length);
   149	    for (const dep of task.dependsOn) {
   150	      const key = idKey(dep);
   151	      dependents.set(key, [...(dependents.get(key) ?? []), idKey(task.id)]);
   152	    }
   153	  }
   154	  const queue = tasks
   155	    .map((t) => idKey(t.id))
   156	    .filter((key) => indegree.get(key) === 0);
   157	  let ordered = 0;
   158	  while (queue.length > 0) {
   159	    const key = queue.shift()!;
   160	    ordered++;
   161	    for (const dependent of dependents.get(key) ?? []) {
   162	      const remaining = indegree.get(dependent)! - 1;
   163	      indegree.set(dependent, remaining);
   164	      if (remaining === 0) queue.push(dependent);
   165	    }
   166	  }
   167	  if (ordered !== tasks.length) {
   168	    const cyclic = tasks
   169	      .filter((t) => (indegree.get(idKey(t.id)) ?? 0) > 0)
   170	      .map((t) => t.id);
   171	    throw new Error(`Plan contains a dependency cycle: ${cyclic.join(", ")}`);
   172	  }
   173	}
   174	
   175	/** Create a validated plan. Throws on cycles, dangling deps, or bad input. */
   176	export function createPlan(
   177	  goal: string,
   178	  tasks: PlanTaskInput[],
   179	  options: CreatePlanOptions = {},
   180	): Plan {
   181	  const normalizedGoal = goal?.trim();
   182	  if (!normalizedGoal) {
   183	    throw new Error("Plan goal must not be empty");
   184	  }
   185	  if (!Array.isArray(tasks) || tasks.length === 0) {
   186	    throw new Error("A plan needs at least one task");
   187	  }
   188	  const built = tasks.map((t) => buildTask(t, options));
   189	  validateDag(built);
   190	  const now = options.now ?? Date.now();
   191	  return { goal: normalizedGoal, tasks: built, createdAt: now, updatedAt: now };
   192	}
   193	
   194	export function getTask(plan: Plan, id: string): PlanTask | undefined {
   195	  return plan.tasks.find((t) => idKey(t.id) === idKey(id));
   196	}
   197	
   198	function requireTask(plan: Plan, id: string): PlanTask {
   199	  const task = getTask(plan, id);
   200	  if (!task) {
   201	    throw new Error(`Unknown task id: ${id}`);
   202	  }
   203	  return task;
   204	}
   205	
   206	/** Tasks dispatchable now: not yet started, with every dependency done. */
   207	export function readySet(plan: Plan): PlanTask[] {
   208	  return plan.tasks.filter(
   209	    (task) =>
   210	      (task.status === "pending" || task.status === "ready") &&
   211	      task.dependsOn.every((dep) => getTask(plan, dep)?.status === "done"),
   212	  );
   213	}
   214	
   215	/** Legal status transitions. Maps from current status to the set of
   216	 * allowed next statuses. Code-enforced with a console.warn on violation;
   217	 * does not throw so manual overrides remain possible. */
   218	const LEGAL_TRANSITIONS: Record<TaskStatus, readonly TaskStatus[]> = {
   219	  pending: ["ready"],
   220	  ready: ["running"],
   221	  running: ["review", "ready", "failed"],
   222	  review: ["done", "ready", "failed"],
   223	  done: [],
   224	  failed: [],
   225	};
   226	
   227	function warnIllegalTransition(
   228	  from: TaskStatus,
   229	  to: TaskStatus,
   230	  taskId: string,
   231	): void {
   232	  console.warn(
   233	    `[planner] Warning: illegal status transition ${from} -> ${to} on task "${taskId}". ` +
   234	    `Legal transitions from ${from}: [${LEGAL_TRANSITIONS[from].join(", ")}]. ` +
   235	    `Proceeding anyway (manual override).`,
   236	  );
   237	}
   238	
   239	/**
   240	 * Return a new plan with one task's status changed. Dispatching a task
   241	 * (transition to "running") counts as an attempt.
   242	 *
   243	 * Logs a warning on illegal transitions but does not throw — manual
   244	 * overrides remain possible.
   245	 */
   246	export function setTaskStatus(
   247	  plan: Plan,
   248	  id: string,
   249	  status: TaskStatus,
   250	  now?: number,
   251	): Plan {
   252	  if (!TASK_STATUSES.includes(status)) {
   253	    throw new Error(`Invalid task status: ${status}`);
   254	  }
   255	  const target = requireTask(plan, id);
   256	  if (target.status !== status && !LEGAL_TRANSITIONS[target.status]?.includes(status)) {
   257	    warnIllegalTransition(target.status, status, id);
   258	  }
   259	  return {
   260	    ...plan,
   261	    updatedAt: now ?? Date.now(),
   262	    tasks: plan.tasks.map((task) =>
   263	      task === target
   264	        ? {
   265	            ...task,
   266	            status,
   267	            attempts:
   268	              status === "running" && task.status !== "running"
   269	                ? task.attempts + 1
   270	                : task.attempts,
   271	          }
   272	        : task,
   273	    ),
   274	  };
   275	}
   276	
   277	/** Fields of a task that may be edited after creation. */
   278	export interface PlanTaskPatch {
   279	  title?: string;
   280	  description?: string;
   281	  agent?: string;
   282	  criteria?: CriterionInput[];
   283	  /** Artifacts produced by the task (set on passing review). */
   284	  artifacts?: ArtifactRef[];
   285	}
   286	
   287	/** Return a new plan with one task edited. */
   288	export function updateTask(
   289	  plan: Plan,
   290	  id: string,
   291	  patch: PlanTaskPatch,
   292	  options: CreatePlanOptions = {},
   293	): Plan {
   294	  const target = requireTask(plan, id);
   295	  const updated: PlanTask = { ...target };
   296	  if (patch.title !== undefined) {
   297	    const title = patch.title.trim();
   298	    if (!title) throw new Error(`Task "${id}" needs a non-empty title`);
   299	    updated.title = title;
   300	  }
   301	  if (patch.description !== undefined) {
   302	    const description = patch.description.trim();
   303	    if (!description) {
   304	      throw new Error(`Task "${id}" needs a non-empty description`);
   305	    }
   306	    updated.description = description;
   307	  }
   308	  if (patch.agent !== undefined) {
   309	    updated.agent = patch.agent.trim() || undefined;
   310	  }
   311	  if (patch.criteria !== undefined) {
   312	    updated.criteria = normalizeCriteria(
   313	      patch.criteria,
   314	      options.passThreshold ?? DEFAULT_PASS_THRESHOLD,
   315	      options.scaleMax ?? DEFAULT_SCALE_MAX,
   316	    );
   317	  }
   318	  if (patch.artifacts !== undefined) {
   319	    updated.artifacts = patch.artifacts;
   320	  }
   321	  return {
   322	    ...plan,
   323	    updatedAt: options.now ?? Date.now(),
   324	    tasks: plan.tasks.map((task) => (task === target ? updated : task)),
   325	  };
   326	}
   327	
   328	/** Return a new plan with follow-up tasks appended (full DAG re-validation). */
   329	export function addTasks(
   330	  plan: Plan,
   331	  tasks: PlanTaskInput[],
   332	  options: CreatePlanOptions = {},
   333	): Plan {
   334	  if (!Array.isArray(tasks) || tasks.length === 0) {
   335	    throw new Error("addTasks needs at least one task");
   336	  }
   337	  const built = tasks.map((t) => buildTask(t, options));
   338	  const all = [...plan.tasks, ...built];
   339	  validateDag(all);
   340	  return { ...plan, updatedAt: options.now ?? Date.now(), tasks: all };
   341	}
   342	
   343	export interface PlanSummary {
   344	  goal: string;
   345	  total: number;
   346	  counts: Record<TaskStatus, number>;
   347	  /** Ids dispatchable now. */
   348	  ready: string[];
   349	  /** Ids that can never run because a (transitive) dependency failed. */
   350	  blocked: string[];
   351	  /** Longest dependency chain of not-yet-done tasks. */
   352	  criticalPathLength: number;
   353	  /** True when every task is done. */
   354	  done: boolean;
   355	}
   356	
   357	/** Ids of tasks transitively blocked by a failed dependency. */
   358	function blockedIds(plan: Plan): string[] {
   359	  const failed = new Set(
   360	    plan.tasks.filter((t) => t.status === "failed").map((t) => idKey(t.id)),
   361	  );
   362	  if (failed.size === 0) return [];
   363	  const blocked = new Set<string>();
   364	  let changed = true;
   365	  while (changed) {
   366	    changed = false;
   367	    for (const task of plan.tasks) {
   368	      const key = idKey(task.id);
   369	      if (failed.has(key) || blocked.has(key) || task.status === "done") {
   370	        continue;
   371	      }
   372	      if (
   373	        task.dependsOn.some(
   374	          (dep) => failed.has(idKey(dep)) || blocked.has(idKey(dep)),
   375	        )
   376	      ) {
   377	        blocked.add(key);
   378	        changed = true;
   379	      }
   380	    }
   381	  }
   382	  return plan.tasks
   383	    .filter((t) => blocked.has(idKey(t.id)))
   384	    .map((t) => t.id);
   385	}
   386	
   387	export function summarizePlan(plan: Plan): PlanSummary {
   388	  const counts: Record<TaskStatus, number> = {
   389	    pending: 0,
   390	    ready: 0,
   391	    running: 0,
   392	    review: 0,
   393	    done: 0,
   394	    failed: 0,
   395	  };
   396	  for (const task of plan.tasks) counts[task.status]++;
   397	
   398	  // Longest chain of unfinished tasks (memoized depth over the DAG).
   399	  const depth = new Map<string, number>();
   400	  const taskDepth = (task: PlanTask): number => {
   401	    const key = idKey(task.id);
   402	    const memo = depth.get(key);
   403	    if (memo !== undefined) return memo;
   404	    const own = task.status === "done" ? 0 : 1;
   405	    const deps = task.dependsOn
   406	      .map((dep) => getTask(plan, dep))
   407	      .filter((t): t is PlanTask => t !== undefined);
   408	    const result =
   409	      own + (deps.length > 0 ? Math.max(...deps.map(taskDepth)) : 0);
   410	    depth.set(key, result);
   411	    return result;
   412	  };
   413	  const criticalPathLength =
   414	    plan.tasks.length > 0 ? Math.max(...plan.tasks.map(taskDepth)) : 0;
   415	
   416	  return {
   417	    goal: plan.goal,
   418	    total: plan.tasks.length,
   419	    counts,
   420	    ready: readySet(plan).map((t) => t.id),
   421	    blocked: blockedIds(plan),
   422	    criticalPathLength,
   423	    done: counts.done === plan.tasks.length,
   424	  };
   425	}
   426	
   427	/** One-line status suitable for a footer/status bar. */
   428	export function statusLine(plan: Plan): string {
   429	  const s = summarizePlan(plan);
   430	  if (s.done) return `plan: complete (${s.total}/${s.total} done)`;
   431	  const parts = [`${s.counts.done}/${s.total} done`];
   432	  if (s.counts.running > 0) parts.push(`${s.counts.running} running`);
   433	  if (s.counts.review > 0) parts.push(`${s.counts.review} in review`);
   434	  if (s.counts.failed > 0) parts.push(`${s.counts.failed} failed`);
   435	  return `plan: ${parts.join(", ")}`;
   436	}
