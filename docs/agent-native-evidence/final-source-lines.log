    18	/** Promote a task from pending through the proper lifecycle to done.
    19	 * Uses the real lifecycle transitions (pending → ready → running → review → done)
    20	 * to avoid illegal-transition warnings in test setup. */
    21	function promoteToDone(plan: Plan, id: string): Plan {
    22	  let p = setTaskStatus(plan, id, "ready");
    23	  p = setTaskStatus(p, id, "running");
    24	  p = setTaskStatus(p, id, "review");
    25	  p = setTaskStatus(p, id, "done");
    26	  return p;
    27	}
