# Kagi API token — get one from https://kagi.com/settings?p=api
KAGI_API_KEY=your_kagi_api_token_here

# Optional API base URL (default: https://kagi.com/api/v0)
KAGI_BASE_URL=https://kagi.com/api/v0

# Default number of results to return, 1-100 (default: 10)
KAGI_LIMIT=10

# Whether to include Kagi's "related searches" suggestions in the output (default: false)
KAGI_INCLUDE_RELATED=false
