   309	  pi.registerTool(
   310	    defineTool({
   311	      name: "spawn_kill",
   312	      label: "spawn: Kill Job",
   313	      description:
   314	        "Stop a running detached job (SIGTERM to its runner; the tmux window, VM, or job files stay for inspection). Jobs that already finished are reported as-is.",
   315	      promptSnippet: "spawn_kill: stop a running detached job.",
   316	      parameters: Type.Object({
   317	        name: Type.String({ description: "Job name (see spawn_jobs)." }),
   318	      }),
   319	      async execute(_id, params) {
   320	        return withJobs(async (jobs) => {
   321	          const job = jobs.find((j) => j.name === params.name);
   322	          if (!job) throw new Error(`No job named "${params.name}".`);
   323	          let dirty = await refreshJob(job);
   324	          let text: string;
   325	          if (isTerminal(job.status)) {
   326	            text = `Job "${job.name}" already finished: ${jobLine(job, Date.now())}`;
   327	          } else {
   328	            // ADR §9: KillResult determines the outcome.
   329	            // KillResult branch 1 — stopped: backend confirmed the process
   330	            // is gone → stamp killed.
   331	            // KillResult branch 2 — alreadyComplete: process already exited
   332	            // → refresh from marker.
   333	            // KillResult branch 3 — warned/unconfirmed: kill sent but
   334	            // unconfirmed → refresh, mark lost.
   335	            let kr;
   336	            try {
   337	              kr = await backends[job.backend].kill(job);
   338	            } catch (e: any) {
   339	              // KillResult branch 3 (thrown): kill threw an error — surface as explicit
   340	              // error; do not stamp killed or lost so the caller can retry.
   341	              job.updatedAt = Date.now();
   342	              dirty = true;
   343	              text = `Kill failed for job "${job.name}": ${e?.message ?? String(e)}.`;
   344	              return {
   345	                result: {
   346	                  content: [{ type: "text" as const, text }],
   347	                  details: { job },
   348	                },
   349	                dirty,
   350	              };
   351	            }
   352	            if (kr.stopped) {
   353	              // KillResult branch 1 — stopped: backend confirms the process is gone.
   354	              // Stamp killed immediately per ADR §6/§9.
   355	              job.status = "killed";
   356	              job.updatedAt = Date.now();
   357	              dirty = true;
   358	              text = `Killed job "${job.name}".`;
   359	            } else if (kr.alreadyComplete) {
   360	              // KillResult branch 2 — alreadyComplete: refresh from the done marker to
   361	              // discover the real terminal status (done/failed).
   362	              try {
   363	                await backends[job.backend].refresh(job);
   364	              } catch {
   365	                // Best-effort; backend already confirmed completion.
   366	              }
   367	              job.updatedAt = Date.now();
   368	              dirty = true;
   369	              text = `Job "${job.name}" already completed: ${jobLine(job, Date.now())}`;
   370	            } else {
   371	              // KillResult branch 3 — warned / unconfirmed: kill sent but backend could
   372	              // not confirm stop.  Refresh from done markers; if still
   373	              // nonterminal, mark lost so the job never stays "running".
   374	              try {
   375	                await backends[job.backend].refresh(job);
   376	              } catch {
   377	                // Best-effort.
   378	              }
   379	              if (!isTerminal(job.status)) {
   380	                job.status = "lost";
   381	              }
   382	              job.updatedAt = Date.now();
   383	              dirty = true;
   384	              text = `Could not kill job "${job.name}": ${kr.message ?? "unknown error"}.`;
   385	            }
   386	          }
   387	          return {
   388	            result: {
   389	              content: [{ type: "text" as const, text }],
   390	              details: { job },
   391	            },
   392	            dirty,
   393	          };
   394	        });
   395	      },
   396	    }),
   397	  );
