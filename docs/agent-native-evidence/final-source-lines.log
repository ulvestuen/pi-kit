   214	    async kill(job: SpawnJob): Promise<KillResult> {
   215	      // Backend KillResult contract (called by killAndStamp, cleanupSpawnToolingJobs, spawn_kill):
   216	      //
   217	      //  - stopped=true:  process confirmed dead (pane_alive was false before kill-window,
   218	      //    or kill-window succeeded).  Caller stamps "killed" immediately.
   219	      //  - alreadyComplete=true, stopped=false:  process was already dead before the kill
   220	      //    attempt (pane_dead on first probe, or race between alive check and kill-window).
   221	      //    Caller refreshes from done marker to discover the real terminal status.
   222	      //  - stopped=false, no alreadyComplete:  kill-window failed and re-probe shows the
   223	      //    pane is still alive.  This is "warned / unconfirmed" — the caller tries to
   224	      //    refresh from done markers and marks "lost" if still nonterminal.
   225	      //  - stopped=false, no alreadyComplete, no window id:  no tmuxWindowId on the job.
   226	      //    Same warned/unconfirmed path in the caller.
   227	      if (job.tmuxWindowId) {
   228	        const alive = await paneAlive(job.tmuxWindowId);
   229	        if (!alive) {
   230	          return { stopped: false, alreadyComplete: true, message: "pane already dead" };
   231	        }
   232	        const killResult = await exec("tmux", ["kill-window", "-t", job.tmuxWindowId]);
   233	        if (killResult.exitCode !== 0) {
   234	          // Race: the pane may have died between the alive check and
   235	          // kill-window; re-probe to distinguish a real failure from a
   236	          // benign race.
   237	          const aliveAfter = await paneAlive(job.tmuxWindowId);
   238	          if (!aliveAfter) {
   239	            return { stopped: false, alreadyComplete: true, message: "pane died during kill" };
   240	          }
   241	          return { stopped: false, message: killResult.stderr.trim() || "kill-window failed" };
   242	        }
   243	        return { stopped: true };
   244	      }
   245	      return { stopped: false, message: "no tmux window id" };
   246	    },
