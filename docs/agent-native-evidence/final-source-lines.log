    26	/**
    27	 * Fallback critic agent used when no "critic" definition is discovered
    28	 * (e.g. a standalone install without the fleet agents directory).
    29	 */
    30	const FALLBACK_CRITIC: AgentDefinition = {
    31	  name: "critic",
    32	  description:
    33	    "Independent read-only reviewer — scores work against explicit criteria.",
    34	  systemPrompt: [
    35	    "You are an independent critic with fresh context. Inspect with your read-only tools, verify claims against the actual files, and score honestly — you have no stake in the work passing.",
    36	    "Grade inflation defeats your purpose. When in doubt, score lower and say why.",
    37	    "Follow the output format requested in the task exactly.",
    38	  ].join("\n"),
    39	  tools: ["read", "grep", "find", "ls"],
    40	  source: "(built-in fallback)",
    41	};
    42	
    43	function renderReview(review: ReviewResult, scaleMax: number): string {
    44	  const lines = [
    45	    `Critic verdict: ${review.passed ? "PASSED" : "FAILED"}`,
    46	  ];
    47	  if (review.scores.length > 0) {
    48	    lines.push("Scores:");
    49	    for (const s of review.scores) {
    50	      lines.push(
    51	        `  ${s.name}: ${s.score}/${scaleMax}` +
    52	          (s.weakness ? ` — ${s.weakness}` : ""),
    53	      );
    54	    }
    55	  }
    56	  if (review.weaknesses.length > 0) {
    57	    lines.push("Weaknesses (fix in this order):");
    58	    for (const w of review.weaknesses) lines.push(`  - ${w}`);
    59	  }
    60	  return lines.join("\n");
    61	}
