   835	        { type: "branch", id: "b1", description: "branch one", location: "loc1" },
   836	        { type: "summary", id: "s1", description: "summary one" },
   837	      ],
   838	    });
   839	    plan = updateTask(plan, "t2", {
   840	      artifacts: [
   841	        { type: "path", id: "p1", description: "output file", location: "/tmp/out" },
   842	      ],
   843	    });
   844	    plan = promoteToDone(plan, "t1");
   845	    plan = promoteToDone(plan, "t2");
   846	    const t3 = getTask(plan, "t3")!;
   847	    const handoff = buildHandoffSection(plan, t3);
   848	    assert.match(handoff, /\[t1\] Task t1:/);
   849	    assert.match(handoff, /\[t2\] Task t2:/);
   850	    assert.match(handoff, /branch: branch one at loc1/);
   851	    assert.match(handoff, /summary: summary one at \(in-tree\)/);
   852	    assert.match(handoff, /path: output file at \/tmp\/out/);
   853	  });
   854	});
