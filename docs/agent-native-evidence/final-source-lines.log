   482	          }
   483	        } else {
   484	          lines.push("", "Nothing to dispatch this wave (waiting on reviews or running tasks).");
   485	        }
   486	
   487	        if (reviewsById.size > 0) {
   488	          lines.push("", "Critic reviews:");
   489	          for (const [id, review] of reviewsById) {
