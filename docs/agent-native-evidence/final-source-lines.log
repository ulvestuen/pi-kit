   109	  if (s.status === "final") {
   110	    return [
   111	      "AUTOMATED ACT PROMPT:",
   112	      "The latest checkpoint is FINAL. Do not keep iterating.",
   113	      "1. State `FINAL`.",
   114	      "2. Summarize what was produced and the evidence that every criterion passed.",
   115	      "3. Mention any assumptions or follow-up risks without weakening the result.",
   116	    ].join("\n");
   117	  }
   118	
   119	  if (s.status === "stopped") {
   120	    return [
   121	      "AUTOMATED STOP PROMPT:",
   122	      "The loop hit its safety limit. Do not claim success.",
   123	      "1. Report which criteria still fail and why.",
   124	      "2. Summarize the best partial result and what would be needed next.",
   125	    ].join("\n");
   126	  }
   127	
   128	  if (!s.latest) {
   129	    return [
   130	      "AUTOMATED PLAN→DO→CHECK PROMPT:",
