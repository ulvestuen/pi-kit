   318	describe("tmux backend", () => {
   319	  it("writes a run script that captures pi's exit code, not tee's", () => {
   320	    const script = buildTmuxRunScript({
   321	      jobName: "j1",
   322	      cwd: "/work dir",
   323	      piCommand: "'pi' '-p' 'task'",
   324	      logPath: "/logs/j1/job.log",
   325	      donePath: "/logs/j1/done",
   326	      errPath: "/logs/j1/err.log",
   327	    });
   328	    assert.ok(
   329	      script.includes(
   330	        `cd '/work dir' || { echo '[pi-spawn] could not cd to /work dir' > '/logs/j1/err.log'; echo 127 > '/logs/j1/done'; exit 127; }`,
   331	      ),
   332	    );
   333	    // stderr must stay out of the teed stream (it would corrupt the JSONL
   334	    // fleet parses), and the done marker must only appear after tee has
   335	    // finished writing the log — otherwise a poller can see "done" and
   336	    // read a log that is still missing the final assistant message.
   337	    assert.ok(
   338	      script.includes(
   339	        `{ 'pi' '-p' 'task'; echo $? > '/logs/j1/done.exit'; } 2> '/logs/j1/err.log' | tee '/logs/j1/job.log'`,
   340	      ),
   341	    );
   342	    assert.ok(script.includes(`mv '/logs/j1/done.exit' '/logs/j1/done'`));
   343	    assert.ok(
   344	      script.indexOf("| tee") < script.indexOf("mv '/logs/j1/done.exit'"),
   345	    );
   346	  });
