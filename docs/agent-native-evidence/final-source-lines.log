   861	// Shared test helper: a fake SpawnBackend for adapter tests.
   862	function backendForAdapter(config: SpawnConfig): {
   863	  backend: SpawnBackend;
   864	  launched: LaunchRequest[];
   865	  killed: string[];
   866	} {
   867	  const launched: LaunchRequest[] = [];
   868	  const killed: string[] = [];
   869	  const backend: SpawnBackend = {
   870	    name: "tmux",
   871	    async available() {
   872	      return undefined;
   873	    },
   874	    async launch(request) {
   875	      launched.push(request);
   876	      const job = runningJob(config, {
   877	        name: request.jobName,
   878	        agent: request.agent.name,
   879	        task: request.task,
   880	        cwd: request.cwd,
   881	      });
   882	      writeFileSync(
   883	        job.logPath!,
   884	        [
   885	          JSON.stringify({ type: "message_end", message: { role: "assistant", content: [{ type: "text", text: "ok" }] } }),
   886	          "",
   887	        ].join("\\n"),
   888	        "utf8",
   889	      );
   890	      return job;
   891	    },
   892	    async refresh(job) {
   893	      if (job.status !== "running") return false;
   894	      job.status = "done";
   895	      job.exitCode = 0;
   896	      job.updatedAt = Date.now();
   897	      return true;
   898	    },
   899	    async output(job, maxBytes) {
   900	      return readLogTail(job.logPath, maxBytes);
   901	    },
   902	    async errorOutput(job, maxBytes) {
   903	      return readErrTail(job.errPath, maxBytes);
   904	    },
   905	    async kill(job) {
   906	      killed.push(job.name);
   907	      return { stopped: true as const };
   908	    },
   909	    async capabilities() {
   910	      return {
   911	        workspaceMount: true,
   912	        cursorOutput: false,
   913	        confirmedKill: true,
   914	        durableLogs: true,
   915	        networkAccess: true,
   916	        hardwareIsolation: false,
   917	      };
   918	    },
   919	  };
   920	  return { backend, launched, killed };
   921	}
   922	
