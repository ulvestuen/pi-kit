     1	/**
     2	 * tmux backend — the local default: each job runs *inside* its own tmux
     3	 * window, detached from the pi session.
     4	 *
     5	 * Unlike fleet's tmux mirror (a visualization of a child the runner owns),
     6	 * here tmux *is* the runner: the window executes the job's run script,
     7	 * which tees pi's text output into the job log and writes the exit code to
     8	 * the done marker. The window survives pi restarts, shows live output, and
     9	 * stays around after the job ends (remain-on-exit) for inspection.
    10	 */
    11	
    12	import { chmodSync, mkdirSync, writeFileSync } from "node:fs";
    13	import * as path from "node:path";
    14	import { sanitizeTmuxName, shellQuote } from "../../fleet/tmux.ts";
    15	import {
    16	  buildEnvExports,
    17	  buildPiShellCommand,
    18	  buildShellCommand,
    19	} from "../agent-command.ts";
    20	import type { SpawnConfig } from "../config.ts";
    21	import type {
    22	  ExecFn,
    23	  LaunchRequest,
    24	  SpawnBackend,
    25	  SpawnJob,
    26	} from "../jobs.ts";
    27	import type { BackendCapabilities, KillResult } from "@pi-kit/agent-types";
    28	import {
    29	  localJobDir,
    30	  readErrTail,
    31	  readLogTail,
    32	  refreshFromLocalMarkers,
    33	} from "./local.ts";
    34	
    35	/**
    36	 * The run script a job's tmux window executes. The exit-code capture rides
    37	 * inside the braces so `$?` is pi's status, not tee's; output is teed so
    38	 * the window shows it live while the log captures it for spawn_output.
    39	 *
    40	 * Two ordering rules make the report-back reliable:
    41	 *  - stderr goes to its own err file, never into the pipe, so it cannot
    42	 *    interleave with (and corrupt) the JSONL stream fleet parses;
    43	 *  - the exit code is staged in a temp file and only published as the done
    44	 *    marker *after* the pipeline — tee included — has finished, so anyone
    45	 *    who sees the marker sees the complete log.
    46	 */
    47	export function buildTmuxRunScript(options: {
    48	  jobName: string;
    49	  cwd: string;
    50	  piCommand: string;
    51	  logPath: string;
    52	  donePath: string;
    53	  errPath: string;
    54	  /** Export lines forwarding API keys: the window inherits the tmux
    55	   * server's environment, not the launching pi session's. */
    56	  envExports?: string[];
    57	}): string {
    58	  const { jobName, cwd, piCommand, logPath, donePath, errPath } = options;
    59	  const exitPath = `${donePath}.exit`;
    60	  const cdFailed = shellQuote(`[pi-spawn] could not cd to ${cwd}`);
    61	  return [
    62	    "#!/bin/sh",
    63	    `# pi-spawn job ${jobName}: runs one detached sub-agent in this window.`,
    64	    ...(options.envExports ?? []),
    65	    `cd ${shellQuote(cwd)} || { echo ${cdFailed} > ${shellQuote(errPath)}; echo 127 > ${shellQuote(donePath)}; exit 127; }`,
    66	    `{ ${piCommand}; echo $? > ${shellQuote(exitPath)}; } 2> ${shellQuote(errPath)} | tee ${shellQuote(logPath)}`,
    67	    `mv ${shellQuote(exitPath)} ${shellQuote(donePath)}`,
    68	    "",
    69	  ].join("\n");
    70	}
