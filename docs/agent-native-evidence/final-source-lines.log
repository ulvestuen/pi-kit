   113	export function createMicrosandboxBackend(
   114	  exec: ExecFn,
   115	  detach: DetachEffects,
   116	  config: SpawnConfig,
   117	): SpawnBackend {
   118	  const removeSandbox = async (job: SpawnJob): Promise<void> => {
   119	    if (!config.msbRemoveSandbox || !job.sandboxName) return;
   120	    await exec(config.msbBinary, ["rm", "--force", job.sandboxName]);
   121	  };
   122	
   123	  return {
   124	    name: "microsandbox",
   125	
   126	    async available() {
   127	      const probe = await exec(config.msbBinary, ["--version"]);
   128	      return probe.exitCode === 0
   129	        ? undefined
   130	        : `${config.msbBinary} is not installed (get it from https://microsandbox.dev, e.g. \`curl -fsSL https://install.microsandbox.dev | sh\`)`;
   131	    },
   132	
   133	    async launch(request: LaunchRequest): Promise<SpawnJob> {
   134	      const now = Date.now();
   135	      const job: SpawnJob = {
   136	        name: request.jobName,
   137	        backend: "microsandbox",
   138	        agent: request.agent.name,
   139	        task: request.task,
   140	        cwd: request.cwd,
   141	        status: "running",
   142	        createdAt: now,
   143	        updatedAt: now,
   144	        sandboxName: sandboxNameFor(request.jobName),
   145	      };
   146	      const jobDir = localJobDir(job, config);
   147	      mkdirSync(jobDir, { recursive: true });
   148	      job.logPath = path.join(jobDir, "job.log");
   149	      job.donePath = path.join(jobDir, "done");
   150	      job.errPath = path.join(jobDir, "err.log");
   151	      const runScript = path.join(jobDir, "run.sh");
   152	      writeFileSync(
   153	        runScript,
   154	        buildGuestRunScript({
   155	          jobName: job.name,
   156	          piCommand: request.command
   157	            ? buildShellCommand(request.command, request.args ?? [])
   158	            : buildPiShellCommand(
   159	                config.piBinary,
   160	                request.agent,
   161	                request.task,
   162	              ),
   163	          envExports: config.msbForwardEnv
   164	            ? buildEnvExports(config.envPassthrough, process.env)
   165	            : [],
   166	          mountCwd: config.msbMountCwd,
   167	        }),
   168	        "utf8",
   169	      );
   170	      chmodSync(runScript, 0o700);
   171	
   172	      job.hostPid = detach.spawnDetached(
   173	        config.msbBinary,
   174	        buildMsbRunArgs(config, job.name, jobDir, request.cwd),
   175	      );
   176	      return job;
   177	    },
   178	
   179	    async refresh(job: SpawnJob): Promise<boolean> {
   180	      const changed = await refreshFromLocalMarkers(job, () =>
   181	        job.hostPid !== undefined ? detach.isPidAlive(job.hostPid) : false,
   182	      );
   183	      // The named sandbox has no value once the job is over (logs live on
   184	      // the host side of the mount); clean it up on the transition.
   185	      if (changed && isTerminal(job.status)) {
   186	        await removeSandbox(job);
   187	      }
   188	      return changed;
   189	    },
   190	
   191	    async output(job: SpawnJob, maxBytes: number): Promise<string> {
   192	      return readLogTail(job.logPath, maxBytes);
   193	    },
   194	
   195	    async errorOutput(job: SpawnJob, maxBytes: number): Promise<string> {
   196	      return readErrTail(job.errPath, maxBytes);
   197	    },
   198	
   199	    async kill(job: SpawnJob): Promise<KillResult> {
   200	      // Backend KillResult contract (called by killAndStamp, cleanupSpawnToolingJobs, spawn_kill):
   201	      //
   202	      //  - stopped=true:  host runner pid confirmed dead after SIGTERM + msb stop.
   203	      //    Caller stamps "killed" immediately.
   204	      //  - alreadyComplete=true, stopped=false:  host runner pid was already dead before
   205	      //    the kill attempt (isPidAlive returns false on first check).  Caller refreshes
   206	      //    from done marker to discover the real terminal status.
   207	      //  - stopped=false, no alreadyComplete:  SIGTERM was sent and msb stop ran, but
   208	      //    the host process is still alive after re-verification ("unconfirmed").
   209	      //    Caller tries to refresh from done markers and marks "lost" if still nonterminal.
   210	      // Check PID first to detect already-complete jobs.
   211	      if (job.hostPid !== undefined && !detach.isPidAlive(job.hostPid)) {
