  2101	// ============================================================================
  2102	// Public spawn_kill tool — semantic-contract tests
  2103	// ============================================================================
  2104	//
  2105	// The spawn_kill tool's kill handler (index.ts) uses the same semantic
  2106	// contract as killAndStamp: inspect KillResult, stamp killed only on
  2107	// stopped, refresh on alreadyComplete, mark lost on warned/unconfirmed,
  2108	// and surface thrown kill errors explicitly. These tests exercise that
  2109	// contract using the same mock-backend pattern as the adapter tests.
  2110	
  2111	/**
  2112	 * Exercise the spawn_kill tool's kill handling logic with a mock backend.
  2113	 * Mirrors the exact branches in the spawn_kill execute handler (index.ts).
  2114	 */
  2115	async function exerciseToolKillHandling(
  2116	  config: SpawnConfig,
  2117	  opts: {
  2118	    killResult?: KillResult;
  2119	    killThrows?: Error;
  2120	    refreshResolvesTo?: string;
  2121	    now?: () => number;
  2122	  },
  2123	): Promise<{ text: string; job: SpawnJob }> {
  2124	  const { backend, killed } = backendForAdapter(config);
  2125	  const now = opts.now ?? (() => Date.now());
  2126	
  2127	  // Override kill.
  2128	  if (opts.killThrows) {
  2129	    backend.kill = async () => { throw opts.killThrows; };
  2130	  } else if (opts.killResult) {
  2131	    backend.kill = async () => opts.killResult!;
  2132	  }
  2133	
  2134	  // Override refresh: pre-kill calls keep running; post-kill calls
  2135	  // (from alreadyComplete / warned-unconfirmed branches) resolve if
  2136	  // refreshResolvesTo is set.
  2137	  const resolvedStatus = opts.refreshResolvesTo;
  2138	  let refreshCalls = 0;
  2139	  backend.refresh = async (job) => {
  2140	    if (job.status !== "running") return false;
  2141	    refreshCalls++;
  2142	    // First call is the pre-kill refresh from the tool.
  2143	    if (refreshCalls === 1) return false;
  2144	    // Subsequent calls are post-kill: resolve if configured.
  2145	    if (resolvedStatus) {
  2146	      job.status = resolvedStatus as any;
  2147	      job.exitCode = resolvedStatus === "done" ? 0 : undefined;
  2148	      job.updatedAt = now();
  2149	      return true;
  2150	    }
  2151	    return false;
  2152	  };
  2153	
  2154	  // Create a running job.
  2155	  const job = runningJob(config, { name: "tool-kill-test" });
  2156	  saveJobs(config.logDir, [job]);
  2157	
  2158	  // Simulate the spawn_kill tool's logic (mirrors index.ts spawn_kill handler).
  2159	  const jobs = loadJobs(config.logDir);
  2160	  const foundJob = jobs.find((j) => j.name === "tool-kill-test")!;
  2161	  let dirty = false;
  2162	
  2163	  // refreshJob first (matches tool's pre-kill refresh)
  2164	  if (!isTerminal(foundJob.status)) {
  2165	    try {
  2166	      const changed = await backend.refresh(foundJob);
  2167	      if (changed) dirty = true;
  2168	    } catch {
  2169	      // refreshJob swallows errors.
  2170	    }
  2171	  }
  2172	
  2173	  let text: string;
  2174	  if (isTerminal(foundJob.status)) {
  2175	    text = `Job "${foundJob.name}" already finished.`;
  2176	  } else {
  2177	    // ADR §9: KillResult determines the outcome.
  2178	    let kr;
  2179	    try {
  2180	      kr = await backend.kill(foundJob);
  2181	    } catch (e: any) {
  2182	      // Kill threw: surface as explicit error.
  2183	      foundJob.updatedAt = now();
  2184	      dirty = true;
  2185	      text = `Kill failed for job "${foundJob.name}": ${e?.message ?? String(e)}.`;
  2186	      if (dirty) saveJobs(config.logDir, jobs);
  2187	      return { text, job: foundJob };
  2188	    }
  2189	    if (kr.stopped) {
  2190	      foundJob.status = "killed";
  2191	      foundJob.updatedAt = now();
  2192	      dirty = true;
  2193	      text = `Killed job "${foundJob.name}".`;
  2194	    } else if (kr.alreadyComplete) {
  2195	      try { await backend.refresh(foundJob); } catch {}
  2196	      foundJob.updatedAt = now();
  2197	      dirty = true;
  2198	      text = `Job "${foundJob.name}" already completed.`;
  2199	    } else {
  2200	      try { await backend.refresh(foundJob); } catch {}
