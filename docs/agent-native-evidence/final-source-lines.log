   126	function parseNumber(
   127	  value: number | string | undefined,
   128	  fallback: number,
   129	  label: string,
   130	): number {
   131	  if (value === undefined || value === "") return fallback;
   132	  const parsed = typeof value === "number" ? value : Number(value);
   133	  if (!Number.isFinite(parsed)) {
   134	    throw new Error(`${label} must be a number (got: ${value})`);
   135	  }
   136	  return parsed;
   137	}
   138	
   139	function parseBoolean(
   140	  value: boolean | string | undefined,
   141	  fallback: boolean,
   142	): boolean {
   143	  if (value === undefined) return fallback;
   144	  if (typeof value === "boolean") return value;
   145	  const normalized = value.trim().toLowerCase();
   146	  if (["1", "true", "yes", "on"].includes(normalized)) return true;
   147	  if (["0", "false", "no", "off"].includes(normalized)) return false;
   148	  return fallback;
   149	}
   150	
   151	function parseBackend(value: string | undefined): SpawnBackendName {
   152	  if (value === undefined || value.trim() === "") return DEFAULT_BACKEND;
   153	  const normalized = value.trim().toLowerCase();
   154	  if ((SPAWN_BACKEND_NAMES as string[]).includes(normalized)) {
   155	    return normalized as SpawnBackendName;
   156	  }
   157	  throw new Error(
   158	    `backend must be one of ${SPAWN_BACKEND_NAMES.join(", ")} (got: ${value})`,
   159	  );
   160	}
   161	
   162	function parseStringList(
   163	  value: string[] | string | undefined,
   164	  fallback: string[],
   165	): string[] {
   166	  if (value === undefined) return fallback;
   167	  const items = Array.isArray(value) ? value : value.split(",");
   168	  const cleaned = items.map((s) => String(s).trim()).filter((s) => s !== "");
   169	  return cleaned;
   170	}
