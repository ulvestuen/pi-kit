    73	function renderDashboard(state: LoopState): string {
    74	  const s = summarizeLoop(state);
    75	  const lines = [
    76	    `lykkja loop — ${s.status.toUpperCase()}`,
    77	    `  Task:       ${s.task}`,
    78	    `  Pass bar:   ${s.passThreshold}/${s.scaleMax}`,
    79	    `  Passes:     ${s.iterationCount}/${s.maxIterations}`,
    80	  ];
    81	  if (s.latest) {
    82	    lines.push("  Latest scores:");
    83	    for (const score of s.latest.scores) {
    84	      const criterion = state.criteria.find(
    85	        (c) => c.name.toLowerCase() === score.name.toLowerCase(),
    86	      );
    87	      const threshold = criterion ? criterion.threshold : s.passThreshold;
    88	      const mark = score.score >= threshold ? "ok " : "LOW";
    89	      lines.push(
    90	        `    [${mark}] ${score.name}: ${score.score}/${threshold}` +
    91	          (score.weakness ? ` — ${score.weakness}` : ""),
    92	      );
    93	    }
    94	    if (s.weakest) {
    95	      lines.push(`  Fix next:   ${s.weakest}`);
    96	    }
    97	  } else {
    98	    lines.push("  No passes recorded yet — PLAN the first step.");
    99	  }
   100	  return lines.join("\n");
   101	}
