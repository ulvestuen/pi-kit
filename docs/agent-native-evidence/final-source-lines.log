     1	import type {
     2	  ExtensionAPI,
     3	  ExtensionContext,
     4	} from "@mariozechner/pi-coding-agent";
     5	import { defineTool } from "@mariozechner/pi-coding-agent";
     6	import { Type } from "@mariozechner/pi-ai";
     7	import { getConfigPath, loadConfig, type PlannerConfig } from "./config.ts";
     8	import {
     9	  addTasks,
    10	  createPlan,
    11	  getTask,
    12	  setTaskStatus,
    13	  statusLine,
    14	  summarizePlan,
    15	  updateTask,
    16	  TASK_STATUSES,
    17	  type Plan,
    18	  type PlanTaskInput,
    19	  type TaskStatus,
    20	} from "./plan.ts";
    21	
    22	const STATE_ENTRY_TYPE = "planner-state";
    23	const STATUS_KEY = "planner";
    24	
    25	function buildSystemPrompt(config: PlannerConfig): string {
    26	  return [
    27	    "You have the planner extension for structured, persistent plans.",
    28	    "For multi-step goals, represent the plan as data instead of prose: call plan_create with a goal and a task DAG — each task gets an id, a full brief, dependencies, and strict acceptance criteria (see the plan-decomposition skill).",
    29	    `Default criterion pass bar is ${config.passThreshold}/${config.scaleMax}.`,
    30	    "Keep the plan current with plan_update as tasks start, finish, fail, or grow follow-ups. Run /plan for the live dashboard.",
    31	  ].join("\n");
    32	}
    33	
    34	function renderDashboard(plan: Plan): string {
    35	  const s = summarizePlan(plan);
    36	  const lines = [
    37	    `plan — ${s.done ? "COMPLETE" : "IN PROGRESS"}`,
    38	    `  Goal:   ${plan.goal}`,
    39	    `  Tasks:  ${s.total} (${TASK_STATUSES.map((st) => `${s.counts[st]} ${st}`)
    40	      .filter((part) => !part.startsWith("0 "))
    41	      .join(", ")})`,
    42	    `  Critical path: ${s.criticalPathLength} task(s) remaining`,
    43	  ];
    44	  if (s.ready.length > 0) lines.push(`  Ready:  ${s.ready.join(", ")}`);
    45	  if (s.blocked.length > 0) {
    46	    lines.push(`  Blocked by failure: ${s.blocked.join(", ")}`);
    47	  }
    48	  lines.push("  Tasks:");
    49	  for (const task of plan.tasks) {
    50	    const deps = task.dependsOn.length > 0 ? ` <- [${task.dependsOn.join(", ")}]` : "";
    51	    const attempts = task.attempts > 0 ? ` (attempt ${task.attempts})` : "";
    52	    const arts = task.artifacts.length > 0
    53	      ? ` {${task.artifacts.length} artifact(s)}`
    54	      : "";
    55	    lines.push(
    56	      `    [${task.status.padEnd(7)}] ${task.id}: ${task.title}${deps}${attempts}${arts}`,
    57	    );
    58	  }
    59	  return lines.join("\n");
    60	}
    61	
    62	const CRITERION_SCHEMA = Type.Object({
    63	  name: Type.String({ description: "Short, unique name of the criterion." }),
    64	  threshold: Type.Optional(
    65	    Type.Number({
    66	      description:
    67	        "Minimum passing score for this criterion. Defaults to the configured pass bar.",
    68	    }),
    69	  ),
    70	});
    71	
    72	const TASK_INPUT_SCHEMA = Type.Object({
    73	  id: Type.String({ description: "Unique task id, e.g. 't1'." }),
    74	  title: Type.String({ description: "Short task title." }),
    75	  description: Type.String({
    76	    description:
    77	      "Full self-contained brief handed to the sub-agent: what to do, relevant paths, constraints.",
    78	  }),
    79	  dependsOn: Type.Optional(
    80	    Type.Array(Type.String(), {
    81	      description: "Ids of tasks that must be done first.",
    82	    }),
    83	  ),
    84	  agent: Type.Optional(
    85	    Type.String({
    86	      description: 'Fleet agent name; defaults to "implementer".',
    87	    }),
    88	  ),
    89	  criteria: Type.Array(CRITERION_SCHEMA, {
    90	    description: "Strict, measurable acceptance criteria for this task.",
    91	    minItems: 1,
    92	  }),
    93	});
    94	
    95	export default function (pi: ExtensionAPI) {
    96	  let config: PlannerConfig;
    97	  try {
    98	    config = loadConfig();
    99	  } catch (e: any) {
   100	    console.error(`[planner] ${e.message}`);
   101	    console.error(
   102	      `[planner] Using defaults. Fix ${getConfigPath()} or the PLANNER_* env vars, then /reload.`,
   103	    );
   104	    config = {
   105	      passThreshold: 8,
   106	      scaleMax: 10,
   107	      defaultAgent: "implementer",
   108	      injectSystemPrompt: true,
   109	      showStatus: true,
   110	    };
   111	  }
   112	
   113	  let plan: Plan | null = null;
   114	
   115	  const updateStatus = (ctx: ExtensionContext) => {
   116	    if (!config.showStatus || !ctx.hasUI) return;
   117	    ctx.ui.setStatus(STATUS_KEY, plan ? statusLine(plan) : undefined);
   118	  };
   119	
   120	  const persist = () => {
   121	    pi.appendEntry(STATE_ENTRY_TYPE, plan ?? undefined);
   122	  };
   123	
   124	  const restoreState = (ctx: ExtensionContext): Plan | null => {
   125	    let latest: Plan | null = null;
   126	    for (const entry of ctx.sessionManager.getEntries()) {
   127	      if (entry.type === "custom" && entry.customType === STATE_ENTRY_TYPE) {
   128	        const data = entry.data as Plan | undefined;
   129	        latest = data && typeof data.goal === "string" ? data : null;
   130	      }
   131	    }
   132	    return latest;
   133	  };
   134	
   135	  pi.registerTool(
   136	    defineTool({
   137	      name: "plan_create",
   138	      label: "planner: Create Plan",
   139	      description:
   140	        "Create a structured plan for a goal: a validated task DAG where every task has an id, a self-contained brief, dependencies, an agent, and strict acceptance criteria. Replaces any existing plan. The plan persists with the session and is tracked with plan_update.",
   141	      promptSnippet:
   142	        "plan_create: turn a goal into a persistent task DAG with per-task acceptance criteria.",
   143	      promptGuidelines: [
   144	        "Use plan_create for multi-step goals so the plan is data, not prose; follow the plan-decomposition skill for task sizing and criteria.",
   145	        "Give every task a self-contained description — sub-agents executing it share none of your context.",
   146	        "Declare dependencies by id and keep independent tasks free of false ordering so they can run in parallel.",
   147	      ],
   148	      parameters: Type.Object({
   149	        goal: Type.String({ description: "The overall goal of the plan." }),
   150	        tasks: Type.Array(TASK_INPUT_SCHEMA, {
   151	          description: "The task DAG.",
   152	          minItems: 1,
   153	        }),
   154	      }),
   155	      async execute(_id, params, _signal, _onUpdate, ctx) {
   156	        plan = createPlan(params.goal, params.tasks as PlanTaskInput[], {
   157	          passThreshold: config.passThreshold,
   158	          scaleMax: config.scaleMax,
   159	        });
   160	        persist();
   161	        updateStatus(ctx);
   162	        pi.events.emit("planner:plan_created", { plan });
   163	
   164	        const text = `Plan created.\n\n${renderDashboard(plan)}`;
   165	        return {
   166	          content: [{ type: "text" as const, text }],
   167	          details: summarizePlan(plan),
   168	        };
   169	      },
   170	    }),
   171	  );
   172	
   173	  pi.registerTool(
   174	    defineTool({
   175	      name: "plan_update",
   176	      label: "planner: Update Plan",
   177	      description:
   178	        "Update the active plan: change task statuses, edit task briefs/criteria/agents, or append follow-up tasks (the DAG is re-validated). Returns the refreshed dashboard.",
   179	      promptSnippet:
   180	        "plan_update: change task statuses, edit tasks, or append follow-up tasks to the active plan.",
   181	      promptGuidelines: [
   182	        "Keep the plan truthful: mark tasks running when dispatched, review when awaiting verification, done only when their criteria verifiably pass, failed when abandoned.",
   183	        "Append follow-up tasks instead of silently widening an existing task's scope.",
   184	      ],
   185	      parameters: Type.Object({
   186	        setStatus: Type.Optional(
   187	          Type.Array(
   188	            Type.Object({
   189	              id: Type.String({ description: "Task id." }),
   190	              status: Type.Union(
   191	                TASK_STATUSES.map((s) => Type.Literal(s)),
   192	                { description: "New status." },
   193	              ),
   194	            }),
   195	            { description: "Status changes to apply." },
   196	          ),
   197	        ),
   198	        edit: Type.Optional(
   199	          Type.Array(
   200	            Type.Object({
   201	              id: Type.String({ description: "Task id." }),
   202	              title: Type.Optional(Type.String()),
   203	              description: Type.Optional(Type.String()),
   204	              agent: Type.Optional(Type.String()),
   205	              criteria: Type.Optional(Type.Array(CRITERION_SCHEMA)),
   206	              artifacts: Type.Optional(
   207	                Type.Array(
   208	                  Type.Object({
   209	                    type: Type.Union([
   210	                      Type.Literal("path"),
   211	                      Type.Literal("branch"),
   212	                      Type.Literal("commit"),
   213	                      Type.Literal("summary"),
   214	                      Type.Literal("patch"),
   215	                      Type.Literal("file-list"),
   216	                    ]),
   217	                    id: Type.String(),
   218	                    description: Type.String(),
   219	                    location: Type.Optional(Type.String()),
   220	                  }),
   221	                  { description: "Artifacts produced by the task (set on passing review)." },
   222	                ),
   223	              ),
   224	            }),
   225	            { description: "Task edits to apply." },
   226	          ),
   227	        ),
   228	        addTasks: Type.Optional(
   229	          Type.Array(TASK_INPUT_SCHEMA, {
   230	            description: "Follow-up tasks to append to the DAG.",
   231	          }),
   232	        ),
   233	      }),
   234	      async execute(_id, params, _signal, _onUpdate, ctx) {
   235	        if (!plan) {
   236	          throw new Error("No active plan. Call plan_create first.");
   237	        }
   238	
   239	        let next = plan;
   240	        const options = {
   241	          passThreshold: config.passThreshold,
   242	          scaleMax: config.scaleMax,
   243	        };
   244	        for (const change of params.setStatus ?? []) {
   245	          next = setTaskStatus(next, change.id, change.status as TaskStatus);
   246	          pi.events.emit("planner:task_status", {
   247	            id: getTask(next, change.id)!.id,
   248	            status: change.status,
   249	          });
   250	        }
   251	        for (const edit of params.edit ?? []) {
   252	          next = updateTask(
   253	            next,
   254	            edit.id,
   255	            {
   256	              title: edit.title,
   257	              description: edit.description,
   258	              agent: edit.agent,
   259	              criteria: edit.criteria,
   260	              artifacts: edit.artifacts,
   261	            },
   262	            options,
   263	          );
   264	        }
   265	        if (params.addTasks && params.addTasks.length > 0) {
   266	          next = addTasks(next, params.addTasks as PlanTaskInput[], options);
   267	        }
   268	
   269	        plan = next;
   270	        persist();
   271	        updateStatus(ctx);
   272	        pi.events.emit("planner:plan_updated", { plan });
   273	
   274	        const text = `Plan updated.\n\n${renderDashboard(plan)}`;
   275	        return {
   276	          content: [{ type: "text" as const, text }],
   277	          details: summarizePlan(plan),
