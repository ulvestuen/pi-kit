   371	              subject: buildReviewSubject(task, result),
   372	              context: `Goal: ${plan!.goal}\n\nTask brief:\n${task.description}`,
   373	              criteria: task.criteria,
   374	              scaleMax,
   375	              artifacts: depArtifacts.length > 0 ? depArtifacts : undefined,
   376	            };
   377	            requests.set(task.id, request);
   378	            return {
   379	              agent: critic.name,
   380	              task: buildCriticPrompt(request),
   381	              cwd: result?.worktreePath,
   382	              timeoutMs: config.reviewTimeoutMs,
   383	            };
   384	          };
   385	
   386	          const runReviews = async (
   387	            targets: PlanTask[],
   388	          ): Promise<Map<string, ReviewResult>> => {
   389	            const specs = targets.map(reviewSpec);
   390	            const outcomes = await runTasks(criticRegistry, specs, {
   391	              ...runnerBase,
   392	              maxBatch: Math.max(specs.length, 1),
   393	            });
   394	            const parsed = new Map<string, ReviewResult>();
   395	            outcomes.forEach((outcome, i) => {
   396	              const task = targets[i];
   397	              const request = requests.get(task.id)!;
   398	              parsed.set(
   399	                task.id,
   400	                outcome.status === "ok"
   401	                  ? parseCriticOutput(outcome.output, request)
   402	                  : {
   403	                      scores: [],
   404	                      passed: false,
   405	                      weaknesses: [
   406	                        `unscorable output: critic run ${outcome.status}`,
   407	                      ],
   408	                      raw: outcome.output,
   409	                    },
   410	              );
   411	            });
   412	            return parsed;
   413	          };
   414	
   415	          const firstPass = await runReviews(reviewTargets);
   416	          // One automatic critic re-run for unscorable reviews before the
   417	          // failed attempt counts.
   418	          const unscorable = reviewTargets.filter(
   419	            (t) => firstPass.get(t.id)!.scores.length === 0,
   420	          );
   421	          const secondPass =
   422	            unscorable.length > 0 && !signal?.aborted
   423	              ? await runReviews(unscorable)
   424	              : new Map<string, ReviewResult>();
   425	          for (const task of reviewTargets) {
   426	            const retry = secondPass.get(task.id);
