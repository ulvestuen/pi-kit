   222	/** Path of the persistent job registry inside the spawn log directory. */
   223	export function registryPath(logDir: string): string {
   224	  return path.join(logDir, "jobs.json");
   225	}
   226	
   227	/**
   228	 * Load the job registry. A missing file is an empty registry; a corrupt
   229	 * one is reported through onError and treated as empty rather than
   230	 * wedging every spawn tool.
   231	 */
   232	export function loadJobs(
   233	  logDir: string,
   234	  onError?: (message: string) => void,
   235	): SpawnJob[] {
   236	  let raw: string;
   237	  try {
   238	    raw = readFileSync(registryPath(logDir), "utf8");
   239	  } catch {
   240	    return [];
   241	  }
   242	  try {
   243	    const parsed = JSON.parse(raw) as RegistryFile;
   244	    if (!parsed || typeof parsed !== "object" || Array.isArray(parsed)) {
   245	      throw new Error("not a job registry");
   246	    }
   247	    const version = typeof parsed.version === "number" ? parsed.version : 0;
   248	    if (!Array.isArray(parsed.jobs)) {
   249	      throw new Error("not a job registry");
   250	    }
   251	    // Schema-validate each record; reject invalid ones with a warning.
   252	    const valid: SpawnJob[] = [];
   253	    let rejected = 0;
   254	    for (const raw of parsed.jobs) {
   255	      const job = validateJob(raw);
   256	      if (job) {
   257	        valid.push(job);
   258	      } else {
   259	        rejected++;
   260	      }
   261	    }
   262	    if (rejected > 0) {
   263	      onError?.(
   264	        `${rejected} invalid job record(s) in registry ${registryPath(logDir)} (v${version}); keeping ${valid.length} valid records`,
   265	      );
   266	    }
   267	    return valid;
   268	  } catch (e: any) {
   269	    onError?.(
   270	      `unreadable job registry ${registryPath(logDir)} (${e?.message ?? e}); starting empty`,
   271	    );
   272	    return [];
   273	  }
   274	}
   275	
   276	/** Persist the registry atomically (write a sibling temp file, rename). */
   277	export function saveJobs(logDir: string, jobs: SpawnJob[]): void {
   278	  mkdirSync(logDir, { recursive: true });
   279	  const file = registryPath(logDir);
   280	  const tmp = `${file}.tmp`;
   281	  const data: RegistryFile = { version: REGISTRY_VERSION, jobs };
   282	  writeFileSync(tmp, `${JSON.stringify(data, null, 2)}\n`, "utf8");
   283	  renameSync(tmp, file);
   284	}
