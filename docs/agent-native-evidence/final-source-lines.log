   620	  /** Fake tmux effects recording calls and in-memory logs. */
   621	  function fakeEffects(behavior: { failCreate?: boolean } = {}) {
   622	    const calls: string[][] = [];
   623	    const logs = new Map<string, string>();
   624	    let sessionExists = false;
   625	    let windowSeq = 0;
   626	    const effects: TmuxEffects = {
   627	      tmux: async (args) => {
   628	        calls.push(args);
   629	        if (args[0] === "has-session") {
   630	          return { exitCode: sessionExists ? 0 : 1, stdout: "", stderr: "" };
   631	        }
   632	        if (args[0] === "new-session" || args[0] === "new-window") {
   633	          if (behavior.failCreate) {
   634	            return { exitCode: 1, stdout: "", stderr: "no server" };
   635	          }
   636	          sessionExists = true;
   637	          return { exitCode: 0, stdout: `@${++windowSeq}\n`, stderr: "" };
   638	        }
   639	        return { exitCode: 0, stdout: "", stderr: "" };
   640	      },
   641	      createLogFile: (label) => {
   642	        const file = `/logs/${label}.log`;
   643	        logs.set(file, "");
   644	        return file;
   645	      },
   646	      appendToLog: (file, text) => {
   647	        logs.set(file, (logs.get(file) ?? "") + text);
   648	      },
   649	    };
   650	    return { effects, calls, logs };
   651	  }
   652	
