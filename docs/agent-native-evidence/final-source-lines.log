   208	/** Schema-validate a single job record. Returns the validated record or null. */
   209	function validateJob(raw: any): SpawnJob | null {
   210	  if (!raw || typeof raw !== "object" || Array.isArray(raw)) return null;
   211	  if (typeof raw.name !== "string" || !raw.name) return null;
   212	  if (!SPAWN_BACKEND_NAMES.includes(raw.backend)) return null;
   213	  if (typeof raw.agent !== "string") return null;
   214	  if (typeof raw.task !== "string") return null;
   215	  if (typeof raw.cwd !== "string") return null;
   216	  if (!"running done failed killed lost".includes(raw.status)) return null;
   217	  if (typeof raw.createdAt !== "number") return null;
   218	  if (typeof raw.updatedAt !== "number") return null;
   219	  return raw as SpawnJob;
   220	}
